@page "/"
@rendermode InteractiveServer
@using VScanMagic.Data
@using VScanMagic.ConnectSecure
@using VScanMagic.Core.Paths
@using VScanMagic.Core.Services
@using VScanMagic.Review
@using VScanMagic.Review.Services
@using VScanMagic.Web.Helpers
@using VScanMagic.Web.Services
@inject VulnerabilityPipeline Pipeline
@inject ReviewSessionFactory SessionFactory
@inject IReviewSessionRepository SessionRepo
@inject SettingsService Settings
@inject ConnectSecureClient CsClient
@inject ConnectSecureReportService ReportService
@inject ReportPathResolver PathResolver
@inject ReportFolderHistoryService FolderHistory
@inject RmitPlusSettingsService RmitPlusSettings
@inject NavigationManager Nav

<PageTitle>Start client review</PageTitle>

<div class="home-hero mb-4">
    <h1 class="home-hero-title">Start client review <HelpTip Text="Download All Vulnerabilities from ConnectSecure (or use a local file), then run the live review session." /></h1>
    <p class="home-hero-lead mb-0">
        Download or upload the ConnectSecure <strong>All Vulnerabilities</strong> XLSX, then run the live review session.
    </p>
</div>

<div class="card home-review-card mb-3">
    <div class="card-header home-review-card-header">
        <span class="home-review-badge">Main workflow</span>
        New review session
    </div>
    <div class="card-body">
        <div class="row mb-3">
            <div class="col-md-6">
                <label class="form-label">Company <HelpTip Text="ConnectSecure company for this review — session company id and folder mapping." /></label>
                <div class="input-group">
                    <select class="form-select" @bind="_selectedCompanyId" @bind:after="OnCompanyChanged">
                        <option value="">-- Select company --</option>
                        @foreach (var c in _companies)
                        {
                            <option value="@c.Id">@c.Name</option>
                        }
                    </select>
                    <button class="btn btn-outline-secondary" type="button" disabled="@_busy" @onclick="LoadCompanies">Refresh</button>
                </div>
                @if (!CsClient.IsConfigured)
                {
                    <div class="form-text text-warning">Configure ConnectSecure on <a href="/settings">Settings</a> to load companies and download reports.</div>
                }
            </div>
            <div class="col-md-6">
                <label class="form-label">Client name</label>
                <input class="form-control" value="@SelectedCompanyName" readonly />
                <div class="form-check mt-2">
                    <input class="form-check-input" type="checkbox" @bind="_isRmitPlus" id="rmitPlusReview" />
                    <label class="form-check-label" for="rmitPlusReview">RMIT+ client <HelpTip Text="Sets client type for this session. Affects email wording, ticket suffixes, and time-estimate billing fields." /></label>
                </div>
                <div class="form-text">
                    @( _isRmitPlus ? "RMIT+ (agreement coverage)" : "RMIT/CMIT (approval required before remediation)" )
                </div>
            </div>
        </div>

        <div class="row mb-3">
            <div class="col-md-6">
                <label class="form-label">Scan date <HelpTip Text="Shown on exports; used for year-quarter folder paths when downloading and exporting deliverables." /></label>
                <input class="form-control" type="date" @bind="_scanDate" @bind:after="RefreshResolvedOutputPath" />
            </div>
            <div class="col-md-6">
                <label class="form-label">Presenter <HelpTip Text="Your name — Prepared By on client email and reports." /></label>
                <input class="form-control" @bind="_presenter" />
            </div>
        </div>

        @if (CsClient.IsConfigured)
        {
            <div class="home-download-section mb-4 pb-3 border-bottom">
                <h2 class="h6 mb-3">1. Download from ConnectSecure <HelpTip Text="Standard quarterly bundle. All Vulnerabilities is selected below for the review session." /></h2>
                <div class="mb-3">
                    <label class="form-label">Output directory <HelpTip Text="Quarterly folder under Reports Base Path when configured. Downloads and exports land here." AlignEnd="true" /></label>
                    <input class="form-control" @bind="_outputDirectory" @bind:after="OnOutputDirectoryChanged" />
                    @if (!string.IsNullOrWhiteSpace(_resolvedPathHint))
                    {
                        <div class="form-text">@_resolvedPathHint</div>
                    }
                </div>

                <p class="fw-semibold mb-2 small">Standard reports</p>
                <div class="row mb-1">
                    @for (var ri = 0; ri < _standardReports.Count; ri++)
                    {
                        var report = _standardReports[ri];
                        var reportIndex = ri;
                        <div class="col-md-6">
                            <div class="form-check">
                                <input class="form-check-input" type="checkbox" checked="@GetReportSelected(report.Type)"
                                       @onclick="e => OnReportCheckboxClick(reportIndex, e)" @onclick:preventDefault
                                       id="@($"rep_{report.Type}")" />
                                <label class="form-check-label" for="@($"rep_{report.Type}")">@report.Name (@report.Extension.ToUpperInvariant())</label>
                            </div>
                        </div>
                    }
                </div>
                <p class="form-text mb-3">Shift-click to select a range. Include <strong>All Vulnerabilities</strong> to start the review below.</p>

                <button class="btn btn-success" disabled="@(_busy || string.IsNullOrEmpty(_selectedCompanyId))" @onclick="DownloadStandardReports">
                    Download selected reports
                </button>

                <QuarterFolderReplacePrompt Visible="@_showQuarterReplacePrompt"
                                            QuarterFolderLabel="@_quarterReplaceLabel"
                                            FileCount="@_quarterReplaceFileCount"
                                            Busy="@_busy"
                                            OnChoice="OnQuarterReplaceChoice" />

                @if (_downloadResult is not null)
                {
                    <div class="alert alert-success mt-3 mb-0 py-2">
                        <strong>Download complete.</strong> Saved to <code class="small">@_downloadResult.OutputDirectory</code>
                        @if (_downloadResult.Succeeded.Count > 0)
                        {
                            <ul class="mb-0 mt-2 small">
                                @foreach (var s in _downloadResult.Succeeded)
                                {
                                    <li>@s.Name</li>
                                }
                            </ul>
                        }
                        @if (_downloadResult.Failed.Count > 0)
                        {
                            <p class="text-danger mb-0 mt-2 small">Failed:</p>
                            <ul class="mb-0 small">
                                @foreach (var f in _downloadResult.Failed)
                                {
                                    <li>@f.Name: @f.Error</li>
                                }
                            </ul>
                        }
                    </div>
                }
            </div>
        }

        <h2 class="h6 mb-3">@(CsClient.IsConfigured ? "2. " : "")Start review from All Vulnerabilities</h2>
        <div class="mb-3">
            <label class="form-label">All Vulnerabilities XLSX <HelpTip Text="Required source file — filled automatically after download, or upload/paste a path. Not Top Ten Data alone." AlignEnd="true" /></label>
            <InputFile OnChange="OnFileSelected" accept=".xlsx,.xls" class="form-control mb-2" />
            <input class="form-control" @bind="_filePath" placeholder="Or path to All Vulnerabilities.xlsx" />
            @if (!string.IsNullOrEmpty(_downloadedAllVulnsPath) && string.Equals(_filePath, _downloadedAllVulnsPath, StringComparison.OrdinalIgnoreCase))
            {
                <div class="form-text text-success">Using file from the download above.</div>
            }
        </div>

        <p class="text-muted small mb-3">
            Network and registry findings appear as candidates in the session — use <strong>Add to export</strong> before the client call.
            Resume past work from <a href="/sessions">Review sessions</a>.
        </p>

        @if (!string.IsNullOrEmpty(_status))
        {
            <div class="alert alert-info py-2">@_status</div>
        }
        @if (!string.IsNullOrEmpty(_error))
        {
            <div class="alert alert-danger py-2">@_error</div>
        }

        <div class="d-flex flex-wrap gap-2">
            <button class="btn btn-primary btn-lg home-start-btn" disabled="@(_busy || string.IsNullOrWhiteSpace(SelectedCompanyName))" @onclick="StartReview">
                Start review session
            </button>
            @if (!string.IsNullOrEmpty(_downloadedAllVulnsPath))
            {
                <button class="btn btn-outline-primary btn-lg" disabled="@_busy" @onclick="StartReviewFromDownload">
                    Start review from download
                </button>
            }
        </div>
    </div>
</div>

<div class="text-center small text-muted">
    <a href="/help">Workflow guide</a>
    ·
    <a href="/report-downloader">Report downloader</a> (catalog / global)
    ·
    <a href="/sessions">Review sessions</a>
</div>

@code {
    [SupplyParameterFromQuery(Name = "allVulns")]
    public string? AllVulnsFromQuery { get; set; }

    [SupplyParameterFromQuery(Name = "stableExport")]
    public int? StableExportFromQuery { get; set; }

    private DateTime _scanDate = DateTime.Today;
    private string _presenter = "";
    private string _filePath = "";
    private string _outputDirectory = "";
    private string? _uploadedPath;
    private string? _status;
    private string? _error;
    private bool _busy;
    private string _selectedCompanyId = "";
    private List<CompanyInfo> _companies = [];
    private List<StandardReportRequest> _standardReports = [];
    private HashSet<string> _selectedReportTypes = new(StringComparer.OrdinalIgnoreCase);
    private DownloadUiResult? _downloadResult;
    private string? _downloadedAllVulnsPath;
    private string? _resolvedPathHint;
    private UserSettings _userSettings = new();
    private bool _isRmitPlus;
    private readonly CheckboxRangeColumn _reportSelectRange = new();
    private bool _showQuarterReplacePrompt;
    private string _quarterReplaceLabel = "";
    private int _quarterReplaceFileCount;
    private ReportOutputLayout? _pendingDownloadLayout;
    private bool _useStableExportNames;

    private string SelectedCompanyName =>
        _companies.FirstOrDefault(c => c.Id == _selectedCompanyId)?.Name ?? "";

    private void OnCompanyChanged()
    {
        _error = null;
        LoadClientTypeForSelectedCompany();
        RefreshResolvedOutputPath();
    }

    private void LoadClientTypeForSelectedCompany()
    {
        var name = SelectedCompanyName.Trim();
        _isRmitPlus = string.IsNullOrWhiteSpace(name)
            ? false
            : RmitPlusSettings.GetOrDefault(name);
    }

    private void OnOutputDirectoryChanged() => _resolvedPathHint = null;

    private void RefreshResolvedOutputPath()
    {
        if (string.IsNullOrEmpty(_selectedCompanyId) || !int.TryParse(_selectedCompanyId, out var companyId))
        {
            _resolvedPathHint = string.IsNullOrWhiteSpace(_userSettings.ReportsBasePath)
                ? null
                : "Reports Base Path is set — select a company to resolve the client/quarter folder.";
            return;
        }

        var layout = PathResolver.Resolve(
            _userSettings,
            companyId,
            SelectedCompanyName,
            _scanDate.ToString("yyyy-MM-dd"),
            fallbackPath: null);

        if (layout.UsesStructuredPaths)
        {
            _outputDirectory = layout.OutputDirectory;
            _resolvedPathHint = layout.ReportsPathPartial is not null
                ? $"Resolved under Reports Base Path: ...\\{layout.ReportsPathPartial}"
                : $"Resolved under Reports Base Path: {layout.OutputDirectory}";
        }
        else
        {
            _resolvedPathHint = null;
        }
    }

    protected override async Task OnInitializedAsync()
    {
        _standardReports = StandardReportCatalog.DefaultCompanyReports.ToList();
        _selectedReportTypes = _standardReports.Select(r => r.Type).ToHashSet(StringComparer.OrdinalIgnoreCase);

        var userSettings = Settings.LoadUserSettings();
        _userSettings = userSettings;
        _presenter = userSettings.PreparedBy;
        if (!string.IsNullOrWhiteSpace(userSettings.ReportsBasePath))
            _outputDirectory = userSettings.ReportsBasePath.Trim();
        else
            _outputDirectory = ReportPathResolver.GetDefaultManualOutputDirectory(userSettings);

        ApplyAllVulnsFromQuery();

        var creds = Settings.LoadConnectSecureCredentials();
        if (!string.IsNullOrWhiteSpace(creds.BaseUrl))
        {
            CsClient.Configure(creds);
            await LoadCompanies();
        }

        RefreshResolvedOutputPath();
    }

    protected override void OnParametersSet() => ApplyAllVulnsFromQuery();

    private void ApplyAllVulnsFromQuery()
    {
        if (string.IsNullOrWhiteSpace(AllVulnsFromQuery))
            return;

        var path = Uri.UnescapeDataString(AllVulnsFromQuery);
        if (!File.Exists(path))
            return;

        _filePath = path;
        _downloadedAllVulnsPath = path;
        _status = "All Vulnerabilities file loaded from Report downloader.";
        if (StableExportFromQuery == 1)
            _useStableExportNames = true;
    }

    private bool GetReportSelected(string type) => _selectedReportTypes.Contains(type);

    private void SetReportSelected(string type, bool selected)
    {
        if (selected) _selectedReportTypes.Add(type);
        else _selectedReportTypes.Remove(type);
    }

    private void OnReportCheckboxClick(int index, MouseEventArgs e)
    {
        if (index < 0 || index >= _standardReports.Count)
            return;

        var type = _standardReports[index].Type;
        var newValue = !GetReportSelected(type);
        _reportSelectRange.Click(index, newValue, e, (i, on) =>
            SetReportSelected(_standardReports[i].Type, on));
    }

    private async Task OnFileSelected(InputFileChangeEventArgs e)
    {
        _error = null;
        var file = e.File;
        var temp = Core.Paths.VScanMagicPaths.GetTempFile("uploads", file.Name);
        await using var stream = file.OpenReadStream(100 * 1024 * 1024);
        await using var fs = File.Create(temp);
        await stream.CopyToAsync(fs);
        _uploadedPath = temp;
        _filePath = temp;
        _status = $"Uploaded {file.Name}";
    }

    private async Task DownloadStandardReports()
    {
        _error = null;
        _status = null;
        _downloadResult = null;
        _downloadedAllVulnsPath = null;
        _showQuarterReplacePrompt = false;

        if (string.IsNullOrEmpty(_selectedCompanyId))
        {
            _error = "Select a company.";
            return;
        }

        if (!int.TryParse(_selectedCompanyId, out var companyId))
        {
            _error = "Invalid company ID.";
            return;
        }

        var clientName = SelectedCompanyName.Trim();
        if (string.IsNullOrWhiteSpace(clientName))
        {
            _error = "Select a company with a valid name.";
            return;
        }

        var layout = PathResolver.Resolve(
            _userSettings,
            companyId,
            clientName,
            _scanDate.ToString("yyyy-MM-dd"),
            fallbackPath: _outputDirectory);
        _outputDirectory = layout.OutputDirectory;

        if (QuarterFolderContentsHelper.HasContent(layout.OutputDirectory))
        {
            _pendingDownloadLayout = layout;
            _quarterReplaceLabel = Path.GetFileName(layout.OutputDirectory.TrimEnd(Path.DirectorySeparatorChar, Path.AltDirectorySeparatorChar));
            _quarterReplaceFileCount = QuarterFolderContentsHelper.CountFiles(layout.OutputDirectory);
            _showQuarterReplacePrompt = true;
            return;
        }

        await ExecuteDownloadAsync(layout, replaceMode: false);
    }

    private async Task OnQuarterReplaceChoice(QuarterFolderReplaceChoice choice)
    {
        _showQuarterReplacePrompt = false;
        if (choice == QuarterFolderReplaceChoice.Cancel || _pendingDownloadLayout is null)
        {
            _pendingDownloadLayout = null;
            return;
        }

        var layout = _pendingDownloadLayout;
        _pendingDownloadLayout = null;
        await ExecuteDownloadAsync(layout, choice == QuarterFolderReplaceChoice.Replace);
    }

    private async Task ExecuteDownloadAsync(ReportOutputLayout layout, bool replaceMode)
    {
        if (!int.TryParse(_selectedCompanyId, out var companyId))
            return;

        var clientName = SelectedCompanyName.Trim();
        _useStableExportNames = replaceMode;
        _busy = true;
        try
        {
            if (replaceMode)
                QuarterFolderContentsHelper.ClearContents(layout.OutputDirectory);

            var outputDir = layout.OutputDirectory;
            var reports = _standardReports.Where(r => _selectedReportTypes.Contains(r.Type)).ToList();
            var downloadOptions = new ReportDownloadOptions(UseStableFilenames: replaceMode);
            var result = await ReportService.DownloadStandardReportsAsync(
                companyId,
                clientName,
                layout,
                reports,
                downloadOptions,
                new Progress<string>(m =>
                {
                    _status = m;
                    _ = InvokeAsync(() =>
                    {
                        StateHasChanged();
                        return Task.CompletedTask;
                    });
                }),
                CancellationToken.None);

            _downloadResult = new DownloadUiResult(outputDir, result.Succeeded.ToList(), result.Failed.ToList());
            _downloadedAllVulnsPath = result.Succeeded
                .FirstOrDefault(s => s.Name.Contains("All Vulnerabilities", StringComparison.OrdinalIgnoreCase))?.Path;

            if (!string.IsNullOrEmpty(_downloadedAllVulnsPath))
            {
                _filePath = _downloadedAllVulnsPath;
                _status = replaceMode
                    ? "All Vulnerabilities ready — quarter folder replaced with stable filenames."
                    : "All Vulnerabilities ready — start the review session below.";
            }
            else
            {
                _status = $"Downloaded {result.Succeeded.Count} report(s), {result.Failed.Count} failed. Select All Vulnerabilities in the bundle to ingest.";
            }

            FolderHistory.Add(clientName, outputDir);

            var userSettings = Settings.LoadUserSettings();
            ReportOutputDirectoryPersistence.UpdateLastOutputDirectory(userSettings, outputDir);
            Settings.SaveUserSettings(userSettings);
            _userSettings = userSettings;

            RefreshResolvedOutputPath();
        }
        catch (Exception ex)
        {
            _error = ex.Message;
        }
        finally
        {
            _busy = false;
        }
    }

    private async Task StartReviewFromDownload()
    {
        if (string.IsNullOrEmpty(_downloadedAllVulnsPath))
            return;

        _filePath = _downloadedAllVulnsPath;
        await StartReview();
    }

    private async Task StartReview()
    {
        _error = null;
        var path = string.IsNullOrWhiteSpace(_filePath) ? _uploadedPath : _filePath;
        if (string.IsNullOrWhiteSpace(path) || !File.Exists(path))
        {
            _error = CsClient.IsConfigured
                ? "Upload or download the All Vulnerabilities XLSX above (not Top Ten Data alone)."
                : "Please upload or specify a valid All Vulnerabilities XLSX.";
            return;
        }

        var clientName = SelectedCompanyName.Trim();
        if (string.IsNullOrWhiteSpace(clientName))
        {
            _error = "Select a company.";
            return;
        }

        _busy = true;
        try
        {
            var settings = Settings.LoadUserSettings();
            var exportFilters = ReportFilters.FromUserSettings(settings);
            var exportTopN = exportFilters.TopN;
            var ingestOptions = new VulnerabilityIngestOptions(
                SupplementDirectory: Path.GetDirectoryName(path),
                CompanyId: int.TryParse(_selectedCompanyId, out var cid) ? cid : null);

            var result = await Pipeline.ProcessFileAsync(path, exportFilters, ingestOptions);
            if (result.Scored.AllFiltered.Count == 0)
            {
                _error = result.AllRecords.Count == 0
                    ? "No vulnerabilities found in this file. Use the ConnectSecure All Vulnerabilities XLSX — not a Top Ten Data export."
                    : "No findings matched the current severity filters. Check Settings → Rules or use a different source file.";
                return;
            }

            var session = SessionFactory.CreateFromScoredResult(
                clientName,
                _scanDate.ToString("yyyy-MM-dd"),
                result.Scored,
                _presenter,
                path,
                _selectedCompanyId,
                exportTopN,
                _isRmitPlus);
            session.OutputDirectory = ResolveSessionOutputDirectory(path) ?? "";
            session.UseStableExportNames = _useStableExportNames;
            HostOsThresholdApplier.Apply(session, settings);
            DeliverableLinksResolver.ApplyDefaultsToSession(session, settings);
            RmitPlusSettings.Set(clientName, _isRmitPlus);

            await SessionRepo.SaveAsync(session);
            Nav.NavigateTo($"/review/{session.Id}");
        }
        catch (Exception ex)
        {
            _error = ex.Message;
        }
        finally
        {
            _busy = false;
        }
    }

    private async Task LoadCompanies()
    {
        _busy = true;
        try
        {
            _companies = (await CsClient.GetCompaniesAsync()).ToList();
            if (_companies.Count > 0 && string.IsNullOrEmpty(_selectedCompanyId))
                _selectedCompanyId = _companies[0].Id;
            OnCompanyChanged();
        }
        catch (Exception ex)
        {
            _error = ex.Message;
        }
        finally
        {
            _busy = false;
        }
    }

    private sealed record DownloadUiResult(string OutputDirectory, List<DownloadedReport> Succeeded, List<FailedReport> Failed);

    private string? ResolveSessionOutputDirectory(string sourceFilePath)
    {
        if (_downloadResult is not null && !string.IsNullOrWhiteSpace(_downloadResult.OutputDirectory))
            return Path.GetFullPath(_downloadResult.OutputDirectory.Trim());

        var fromFile = SessionOutputLayoutResolver.InferQuarterDirectoryFromSourceFile(sourceFilePath);
        if (!string.IsNullOrWhiteSpace(fromFile))
            return fromFile;

        if (string.IsNullOrWhiteSpace(SelectedCompanyName))
            return null;

        var companyId = int.TryParse(_selectedCompanyId, out var id) ? id : 0;
        var layout = PathResolver.Resolve(
            _userSettings,
            companyId,
            SelectedCompanyName.Trim(),
            _scanDate.ToString("yyyy-MM-dd"),
            _outputDirectory);
        return layout.OutputDirectory;
    }
}
