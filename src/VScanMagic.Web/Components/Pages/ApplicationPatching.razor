@page "/application-patching"
@rendermode InteractiveServer
@implements IAsyncDisposable
@using VScanMagic.ConnectSecure
@using VScanMagic.Web.Services
@inject ConnectSecureClient ConnectSecure
@inject ConnectSecurePatchService PatchService
@inject ConnectSecureScanService ScanService
@inject SettingsService Settings
@inject CompanyListService CompanyList
@inject LoadTimingDisplay LoadTiming

<PageTitle>Application Patching</PageTitle>

<h1>Application Patching</h1>
<p class="text-muted">
    Patchable third-party apps from ConnectSecure remediation plan data. ConnectSecure may return multiple rows per product;
    this page groups them by product and deduplicates hosts. Agent online/offline follows the ConnectSecure Agents view (lightweight and probe), using <code>last_ping_time</code> — not remediation <code>online_status</code>.
    Only online agents can be patched. After patching, use <strong>Refresh inventory</strong> on selected hosts to queue an agent scan (does not install patches). Then use <strong>Check version</strong>.
    See also <a href="os-patching">OS Patching</a> and <a href="vulnerability-suppress">Suppress vulnerabilities</a>.
    <a href="company-review">Company Review</a> covers tenant configuration checks, scan targets, and scan triggers.
</p>

@if (!ConnectSecure.IsConfigured)
{
    <div class="alert alert-warning">Configure ConnectSecure credentials on <a href="settings">Settings</a> first.</div>
}
else
{
    <div class="card mb-3">
        <div class="card-body">
            <div class="row g-3 align-items-end">
                <div class="col-md-8">
                    <label class="form-label">Company</label>
                    <div class="input-group">
                        <select class="form-select" @bind="_selectedCompanyId" @bind:after="OnCompanySelectionChanged">
                            <option value="">-- Select company --</option>
                            @foreach (var c in _companies)
                            {
                                <option value="@c.Id">@c.Name</option>
                            }
                        </select>
                        <button class="btn btn-outline-secondary" type="button" disabled="@_busy" @onclick="LoadCompanies">Refresh</button>
                    </div>
                </div>
                <div class="col-md-4">
                    <button class="btn btn-primary w-100" disabled="@(_busy || string.IsNullOrEmpty(_selectedCompanyId))" @onclick="LoadPatchableApplicationsAsync">
                        Load patchable apps
                    </button>
                    @if (!string.IsNullOrWhiteSpace(LoadTiming.ResultText))
                    {
                        <div class="form-text mt-1">@LoadTiming.ResultText</div>
                    }
                </div>
            </div>
        </div>
    </div>
}

@if (!string.IsNullOrEmpty(_message))
{
    <div class="alert alert-success">@_message</div>
}
@if (!string.IsNullOrEmpty(_error))
{
    <div class="alert alert-danger">@_error</div>
}

@if (_loaded)
{
    <PatchActivityTable @ref="_patchActivityTable"
                        CompanyId="_companyId"
                        Busy="_busy"
                        VerificationMessageChanged="SetVerificationMessage"
                        VerificationErrorChanged="SetVerificationError" />

    <div class="card">
        <div class="card-header d-flex justify-content-between align-items-center flex-wrap gap-2">
            <span>Patchable products</span>
            <div class="d-flex align-items-center gap-2 flex-wrap">
                @if (_loadingPatchApps)
                {
                    <span class="text-muted small">Loading…</span>
                }
                else
                {
                    <span class="badge text-bg-secondary">@VisibleProductGroups.Count products</span>
                    @if (_rawEntryCount > VisibleProductGroups.Count)
                    {
                        <span class="text-muted small">(@_rawEntryCount CS entries)</span>
                    }
                }
                <button type="button" class="btn btn-sm btn-outline-secondary"
                        disabled="@(_busy || _loadingPatchApps || _companyId <= 0)"
                        @onclick="RefreshPatchableApplicationsAsync">
                    Refresh
                </button>
            </div>
        </div>
        <div class="card-body">
            @if (_loadingPatchApps)
            {
                <p class="text-muted mb-0">Loading patchable applications…</p>
            }
            else if (_rawEntryCount == 0)
            {
                <p class="text-muted mb-0">No patchable applications reported for this company.</p>
            }
            else
            {
                <div class="row g-2 align-items-end mb-3">
                    <div class="col-md-4">
                        <label class="form-label">Severity</label>
                        <select class="form-select form-select-sm" @bind="_severityFilter" @bind:after="OnPatchFiltersChangedAsync">
                            <option value="all">All</option>
                            <option value="critical">Critical only</option>
                            <option value="high+">Critical + High</option>
                        </select>
                    </div>
                    <div class="col-md-4">
                        <div class="form-check mt-4">
                            <input class="form-check-input" type="checkbox" id="hideEol" @bind="_hideEndOfLife" @bind:after="OnPatchFiltersChangedAsync" />
                            <label class="form-check-label" for="hideEol">Hide end-of-life products</label>
                        </div>
                    </div>
                </div>

                @if (VisibleProductGroups.Count == 0)
                {
                    <p class="text-muted mb-0">No products match the current filters (@_rawEntryCount CS entries loaded).</p>
                }
                else
                {
                    <div class="table-responsive">
                        <table class="table table-sm align-middle mb-0">
                            <thead class="table-light">
                                <tr>
                                    <th>Product</th>
                                    <th>Severity</th>
                                    <th class="text-end">Hosts</th>
                                    <th>Patch to</th>
                                    <th></th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var product in VisibleProductGroups)
                                {
                                    var expanded = string.Equals(_expandedProduct, product.Product, StringComparison.OrdinalIgnoreCase);
                                    <tr class="@(expanded ? "table-active" : null)">
                                        <td class="fw-semibold">
                                            @product.Product
                                            @if (product.RemediationEntryCount > 1)
                                            {
                                                <span class="badge text-bg-light border ms-1">@product.RemediationEntryCount CS entries</span>
                                            }
                                            @if (product.IsEndOfLife)
                                            {
                                                <span class="badge text-bg-warning ms-1">EOL</span>
                                            }
                                        </td>
                                        <td>@product.Severity</td>
                                        <td class="text-end">@product.ReportedAssets</td>
                                        <td class="small text-muted">@PatchCatalogHelper.FormatFixSummary(product.TargetFix)</td>
                                        <td class="text-end text-nowrap">
                                            <button type="button" class="btn btn-sm btn-outline-primary"
                                                    disabled="@_loadingPatchAssets"
                                                    @onclick="() => TogglePatchProductAsync(product)">
                                                @(expanded ? "Hide" : "Hosts")
                                            </button>
                                        </td>
                                    </tr>
                                    @if (expanded)
                                    {
                                        <tr>
                                            <td colspan="5" class="bg-light">
                                                @if (_loadingPatchAssets)
                                                {
                                                    <p class="text-muted mb-0 py-2">Loading hosts…</p>
                                                }
                                                else if (_patchHostViews.Count == 0)
                                                {
                                                    <p class="text-muted mb-0 py-2">No online or offline hosts returned for this product.</p>
                                                }
                                                else
                                                {
                                                    <div class="d-flex justify-content-between align-items-center flex-wrap gap-2 mb-2">
                                                        <div class="small text-muted">
                                                            @_selectedPatchAgentIds.Count of @_patchHostViews.Count host(s) selected
                                                            · @(_patchHostViews.Count(t => t.Detail.OnlineStatus)) online
                                                            · @(_patchHostViews.Count(t => !t.Detail.OnlineStatus)) offline
                                                            · @(_patchHostViews.Count(t => t.Status == HostPatchStatus.AtTarget)) at target
                                                        </div>
                                                        <div class="btn-group btn-group-sm">
                                                            <button type="button" class="btn btn-outline-secondary"
                                                                    disabled="@_loadingPatchAssets"
                                                                    @onclick="RefreshExpandedHostsAsync">
                                                                Refresh hosts
                                                            </button>
                                                            <button type="button" class="btn btn-outline-secondary"
                                                                    @onclick="SelectAllOnlinePatchAgents">
                                                                Select online
                                                            </button>
                                                            <button type="button" class="btn btn-outline-secondary"
                                                                    disabled="@(_loadingPatchAssets || _agentUpdateBusy || _selectedPatchAgentIds.Count == 0)"
                                                                    @onclick="RequestAgentUpdateForSelectedAsync">
                                                                @(_agentUpdateBusy ? "Requesting…" : "Refresh inventory")
                                                            </button>
                                                            <button type="button" class="btn btn-outline-secondary"
                                                                    @onclick="ClearPatchAgentSelection">
                                                                Clear
                                                            </button>
                                                        </div>
                                                    </div>
                                                    <div class="table-responsive">
                                                        <table class="table table-sm mb-2">
                                                            <thead>
                                                                <tr>
                                                                    <th style="width: 2rem;"></th>
                                                                    <th>Host</th>
                                                                    <th>IP</th>
                                                                    <th>Agent</th>
                                                                    <th>Installed</th>
                                                                    <th>Connectivity</th>
                                                                    <th>Patch status</th>
                                                                </tr>
                                                            </thead>
                                                            <tbody>
                                                                @foreach (var host in _patchHostViews)
                                                                {
                                                                    var target = host.Detail;
                                                                    var agentId = target.AgentId;
                                                                    var selectable = CanSelectHost(host);
                                                                    var selected = agentId > 0 && _selectedPatchAgentIds.Contains(agentId);
                                                                    <tr class="@(target.OnlineStatus ? null : "table-warning")">
                                                                        <td>
                                                                            @if (selectable)
                                                                            {
                                                                                <input type="checkbox" class="form-check-input"
                                                                                       checked="@selected"
                                                                                       @onchange="e => TogglePatchAgent(agentId, e.Value is true)" />
                                                                            }
                                                                            else if (agentId <= 0)
                                                                            {
                                                                                <span class="text-muted small" title="No agent id reported">—</span>
                                                                            }
                                                                        </td>
                                                                        <td>
                                                                            @target.HostName
                                                                            @if (!string.IsNullOrWhiteSpace(target.RegisteredHostName) &&
                                                                                 !string.Equals(target.HostName, target.RegisteredHostName, StringComparison.OrdinalIgnoreCase))
                                                                            {
                                                                                <span class="text-muted small"> (agent: @target.RegisteredHostName)</span>
                                                                            }
                                                                        </td>
                                                                        <td><code>@target.Ip</code></td>
                                                                        <td><PatchAgentStatusCell Detail="target" /></td>
                                                                        <td class="small">@PatchCatalogHelper.FormatVersionSummary(target.Versions)</td>
                                                                        <td><PatchAgentConnectivityCell Detail="target" /></td>
                                                                        <td>
                                                                            <span class="@PatchStatusClass(host.Status)">@host.StatusLabel</span>
                                                                        </td>
                                                                    </tr>
                                                                }
                                                            </tbody>
                                                        </table>
                                                    </div>
                                                    @if (string.Equals(_confirmProduct, product.Product, StringComparison.OrdinalIgnoreCase))
                                                    {
                                                        <div class="alert alert-warning py-2 mb-2">
                                                            Patch <strong>@product.Product</strong> on @_selectedPatchAgentIds.Count host(s) now?
                                                            @if (product.IsEndOfLife || SelectedHostsIncludeEndOfLife())
                                                            {
                                                                <span> ConnectSecure marks this product as end-of-life; patching may not succeed.</span>
                                                            }
                                                        </div>
                                                        <div class="d-flex gap-2">
                                                            <button type="button" class="btn btn-sm btn-danger"
                                                                    disabled="@(_patching || _selectedPatchAgentIds.Count == 0)"
                                                                    @onclick="() => ConfirmPatchNowAsync(product)">
                                                                @(_patching ? "Patching…" : "Confirm patch now")
                                                            </button>
                                                            <button type="button" class="btn btn-sm btn-outline-secondary"
                                                                    disabled="@_patching"
                                                                    @onclick="CancelPatchConfirm">
                                                                Cancel
                                                            </button>
                                                        </div>
                                                    }
                                                    else
                                                    {
                                                        <button type="button" class="btn btn-sm btn-warning"
                                                                disabled="@(_patching || _selectedPatchAgentIds.Count == 0)"
                                                                @onclick="() => BeginPatchConfirm(product.Product)">
                                                            Patch selected now
                                                        </button>
                                                    }
                                                }
                                            </td>
                                        </tr>
                                    }
                                }
                            </tbody>
                        </table>
                    </div>
                }
            }
        </div>
    </div>
}

@code {
    private List<CompanyInfo> _companies = [];
    private string _selectedCompanyId = "";
    private int _companyId;
    private bool _loaded;
    private string? _error;
    private string? _message;
    private bool _busy;
    private List<PatchableApplicationEntry> _patchableApps = [];
    private List<PatchableApplicationEntry> _allPatchableApps = [];
    private List<PatchableProductGroup> _productGroups = [];
    private int _rawEntryCount;
    private string _severityFilter = "high+";
    private bool _hideEndOfLife;
    private bool _loadingPatchApps;
    private bool _loadingPatchAssets;
    private bool _patching;
    private bool _agentUpdateBusy;
    private string? _expandedProduct;
    private PatchableProductGroup? _expandedProductGroup;
    private string? _confirmProduct;
    private List<PatchAssetDetail> _patchAssetDetails = [];
    private List<PatchHostView> _patchHostViews = [];
    private readonly HashSet<int> _selectedPatchAgentIds = [];
    private readonly Dictionary<string, List<PatchHostView>> _expandedHostCache = new(StringComparer.OrdinalIgnoreCase);
    private int _loadGeneration;
    private int _expandGeneration;
    private CancellationTokenSource? _loadCts;
    private PatchActivityTable? _patchActivityTable;

    private CancellationToken LoadCancellationToken => _loadCts?.Token ?? CancellationToken.None;

    private IReadOnlyList<PatchableProductGroup> VisibleProductGroups => _productGroups;

    protected override async Task OnInitializedAsync()
    {
        _loadCts = new CancellationTokenSource();
        if (ConnectSecure.IsConfigured)
            await LoadCompanies();
    }

    public async ValueTask DisposeAsync()
    {
        if (_loadCts is not null)
        {
            await _loadCts.CancelAsync();
            _loadCts.Dispose();
        }
    }

    private async Task LoadCompanies()
    {
        _error = null;
        _message = null;
        _busy = true;
        try
        {
            _companies = (await CompanyList.GetCompaniesAsync(LoadCancellationToken)).ToList();
        }
        catch (OperationCanceledException)
        {
        }
        catch (Exception ex)
        {
            _error = ex.Message;
        }
        finally
        {
            _busy = false;
        }
    }

    private void OnCompanySelectionChanged()
    {
        if (_loaded && int.TryParse(_selectedCompanyId, out var selected) && selected == _companyId)
            return;

        if (string.IsNullOrEmpty(_selectedCompanyId) || !int.TryParse(_selectedCompanyId, out _))
        {
            ClearLoadedCompanyState();
            return;
        }

        if (_loaded)
            ClearLoadedCompanyState();
    }

    private void ClearLoadedCompanyState()
    {
        _loadGeneration++;
        _expandGeneration++;
        _companyId = 0;
        _loaded = false;
        _error = null;
        _message = null;
        _patchableApps = [];
        _allPatchableApps = [];
        _productGroups = [];
        _rawEntryCount = 0;
        _expandedProduct = null;
        _expandedProductGroup = null;
        _confirmProduct = null;
        _patchAssetDetails = [];
        _patchHostViews = [];
        _selectedPatchAgentIds.Clear();
        _expandedHostCache.Clear();
    }

    private static string ExpandCacheKey(int companyId, PatchableProductGroup product) =>
        $"{companyId}:{string.Join(',', product.SolutionIds.OrderBy(id => id))}";

    private Task LoadPatchableApplicationsAsync() => LoadPatchableApplicationsAsync(forceRefresh: false);

    private Task RefreshPatchableApplicationsAsync() => LoadPatchableApplicationsAsync(forceRefresh: true);

    private async Task LoadPatchableApplicationsAsync(bool forceRefresh)
    {
        if (!int.TryParse(_selectedCompanyId, out var companyId) || companyId <= 0)
            return;

        var sameCompany = _loaded && _companyId == companyId;
        if (sameCompany && !forceRefresh)
            forceRefresh = true; // re-click of Load on the same company should refresh.

        _companyId = companyId;
        _loaded = true;
        _error = null;
        _message = null;
        _loadingPatchApps = true;
        _expandedProduct = null;
        _confirmProduct = null;
        _patchAssetDetails = [];
        _selectedPatchAgentIds.Clear();
        _busy = true;
        var generation = ++_loadGeneration;
        LoadTiming.Start(forceRefresh ? "Refresh patchable apps" : "Load patchable apps");

        try
        {
            _allPatchableApps = (await PatchService.GetPatchableApplicationsAsync(
                _companyId,
                loadOptions: new PatchApplicationLoadOptions
                {
                    SeverityFilter = "all",
                    HideEndOfLife = false
                },
                forceRefresh: forceRefresh,
                ct: LoadCancellationToken)).ToList();
            if (generation != _loadGeneration)
                return;

            ApplyPatchableAppFilters();
            _expandedHostCache.Clear();
            LoadTiming.Complete($"{_allPatchableApps.Count} apps");
        }
        catch (OperationCanceledException)
        {
            LoadTiming.Fail("cancelled");
        }
        catch (Exception ex)
        {
            LoadTiming.Fail(ex.Message);
            _error = ex.Message;
            _patchableApps = [];
            _allPatchableApps = [];
            _productGroups = [];
            _rawEntryCount = 0;
        }
        finally
        {
            _loadingPatchApps = false;
            _busy = false;
        }
    }

    private async Task TogglePatchProductAsync(PatchableProductGroup product)
    {
        if (string.Equals(_expandedProduct, product.Product, StringComparison.OrdinalIgnoreCase))
        {
            _expandedProduct = null;
            _expandedProductGroup = null;
            _confirmProduct = null;
            _patchAssetDetails = [];
            _patchHostViews = [];
            _selectedPatchAgentIds.Clear();
            return;
        }

        _expandedProduct = product.Product;
        _expandedProductGroup = product;
        _confirmProduct = null;
        _patchAssetDetails = [];
        _patchHostViews = [];
        _selectedPatchAgentIds.Clear();
        var generation = ++_expandGeneration;
        await LoadExpandedHostsAsync(product, generation);
    }

    private async Task RefreshExpandedHostsAsync()
    {
        if (_expandedProductGroup is null)
            return;

        _loadingPatchAssets = true;
        try
        {
            _expandedHostCache.Remove(ExpandCacheKey(_companyId, _expandedProductGroup));
            PatchService.InvalidatePatchHostsCache(_companyId);
            await LoadExpandedHostsAsync(_expandedProductGroup, _expandGeneration, useUiCache: false);
        }
        finally
        {
            _loadingPatchAssets = false;
        }
    }

    private async Task LoadExpandedHostsAsync(PatchableProductGroup product, int generation, bool useUiCache = true)
    {
        _loadingPatchAssets = true;
        try
        {
            var cacheKey = ExpandCacheKey(_companyId, product);
            if (useUiCache && _expandedHostCache.TryGetValue(cacheKey, out var cachedViews))
            {
                if (generation != _expandGeneration)
                    return;

                _patchHostViews = cachedViews;
                _patchAssetDetails = cachedViews.Select(view => view.Detail).ToList();
                SelectAllOnlinePatchAgents();
                return;
            }

            var details = (await PatchService.GetPatchingAssetDetailsForProductAsync(
                _companyId,
                product.SolutionIds,
                product.Product,
                LoadCancellationToken)).ToList();
            if (generation != _expandGeneration)
                return;

            _patchAssetDetails = details;
            _patchHostViews = PatchCatalogHelper.BuildHostViews(
                _patchAssetDetails,
                product.TargetFix,
                product.IsEndOfLife).ToList();
            _expandedHostCache[cacheKey] = _patchHostViews;
            SelectAllOnlinePatchAgents();
        }
        catch (OperationCanceledException)
        {
        }
        catch (Exception ex)
        {
            _error = ex.Message;
        }
        finally
        {
            _loadingPatchAssets = false;
        }
    }

    private async Task OnPatchFiltersChangedAsync()
    {
        if (!_loaded || _companyId <= 0)
            return;

        ApplyPatchableAppFilters();
        await InvokeAsync(StateHasChanged);
    }

    private void ApplyPatchableAppFilters()
    {
        _patchableApps = _allPatchableApps
            .Where(entry => PatchCatalogHelper.MeetsSeverityFilter(entry.Severity, _severityFilter))
            .Where(entry => !_hideEndOfLife || !PatchCatalogHelper.IsEndOfLifeProductFix(entry.Fix))
            .ToList();
        _rawEntryCount = _allPatchableApps.Count;
        _productGroups = PatchCatalogHelper.GroupByProduct(_patchableApps).ToList();
    }

    private static bool CanSelectHost(PatchHostView host) =>
        host.Detail.AgentId > 0 && host.Detail.OnlineStatus;

    private void TogglePatchAgent(int agentId, bool selected)
    {
        if (agentId <= 0)
            return;

        if (selected)
            _selectedPatchAgentIds.Add(agentId);
        else
            _selectedPatchAgentIds.Remove(agentId);

        _confirmProduct = null;
    }

    private void SelectAllOnlinePatchAgents()
    {
        _selectedPatchAgentIds.Clear();
        foreach (var host in _patchHostViews.Where(CanSelectHost))
            _selectedPatchAgentIds.Add(host.Detail.AgentId);
        _confirmProduct = null;
    }

    private bool SelectedHostsIncludeEndOfLife() =>
        _patchHostViews.Any(h =>
            _selectedPatchAgentIds.Contains(h.Detail.AgentId) &&
            h.Status == HostPatchStatus.EndOfLife);

    private void ClearPatchAgentSelection()
    {
        _selectedPatchAgentIds.Clear();
        _confirmProduct = null;
    }

    private void BeginPatchConfirm(string product) => _confirmProduct = product;

    private void CancelPatchConfirm() => _confirmProduct = null;

    private async Task ConfirmPatchNowAsync(PatchableProductGroup product)
    {
        if (_companyId <= 0 || _selectedPatchAgentIds.Count == 0)
            return;

        _error = null;
        _message = null;
        _patching = true;

        try
        {
            var selectedTargets = _patchHostViews
                .Where(h => _selectedPatchAgentIds.Contains(h.Detail.AgentId))
                .Select(h => h.Detail)
                .ToList();
            var agentIds = selectedTargets.Select(t => t.AgentId).Distinct().ToList();
            var assetIds = selectedTargets
                .Select(t => t.AssetId > 0 ? t.AssetId : t.AgentId)
                .Distinct()
                .ToList();
            var fromVersions = new Dictionary<string, string>(StringComparer.Ordinal);
            foreach (var target in selectedTargets)
            {
                var version = target.Versions.FirstOrDefault();
                if (string.IsNullOrWhiteSpace(version))
                    continue;

                var versionKey = (target.AssetId > 0 ? target.AssetId : target.AgentId).ToString();
                fromVersions[versionKey] = version;
            }

            var result = await PatchService.PatchApplicationsNowAsync(new ApplicationPatchRequest
            {
                CompanyId = _companyId,
                AgentIds = agentIds,
                AssetIds = assetIds,
                IncludedApplications = [product.Product],
                FromVersions = fromVersions,
                TargetHostNames = selectedTargets
                    .Select(t => t.HostName)
                    .Where(name => !string.IsNullOrWhiteSpace(name))
                    .Distinct(StringComparer.OrdinalIgnoreCase)
                    .ToList(),
                SolutionIds = product.SolutionIds,
                TargetFix = product.TargetFix,
                IsEndOfLife = product.IsEndOfLife
            });

            _message = await BuildPatchSuccessMessageAsync(result.Message, agentIds);
            _confirmProduct = null;
            if (_patchActivityTable is not null)
                await _patchActivityTable.RefreshAsync();
            if (_expandedProductGroup is not null)
                await RefreshExpandedHostsAsync();
            if (!string.IsNullOrWhiteSpace(result.JobId) && _patchActivityTable is not null)
                await _patchActivityTable.VerifyJobAsync(result.JobId);
        }
        catch (Exception ex)
        {
            _error = ex.Message;
        }
        finally
        {
            _patching = false;
        }
    }

    private async Task RequestAgentUpdateForSelectedAsync()
    {
        if (_companyId <= 0 || _selectedPatchAgentIds.Count == 0)
            return;

        _error = null;
        _message = null;
        _agentUpdateBusy = true;
        try
        {
            var agentIds = _selectedPatchAgentIds.Where(id => id > 0).Distinct().ToList();
            var result = await ScanService.TriggerAgentUpdatesAsync(_companyId, agentIds, LoadCancellationToken);
            _message = $"{result.Message} Use Check version after agents report updated inventory (inventory scan only; does not install patches).";
        }
        catch (Exception ex)
        {
            _error = ex.Message;
        }
        finally
        {
            _agentUpdateBusy = false;
        }
    }

    private async Task<string> BuildPatchSuccessMessageAsync(string patchMessage, IReadOnlyList<int> agentIds)
    {
        try
        {
            var update = await ScanService.TriggerAgentUpdatesAsync(_companyId, agentIds, LoadCancellationToken);
            return $"{patchMessage} {update.Message} Use Check version after agents finish installing and reporting back.";
        }
        catch
        {
            return $"{patchMessage} Request agent update on selected hosts, then use Check version after agents report back.";
        }
    }

    private static string PatchStatusClass(HostPatchStatus status) =>
        status switch
        {
            HostPatchStatus.AtTarget => "text-success",
            HostPatchStatus.Pending => "text-primary",
            HostPatchStatus.Offline => "text-warning",
            HostPatchStatus.EndOfLife => "text-danger",
            _ => "text-muted"
        };

    private Task SetVerificationMessage(string? message)
    {
        if (!string.IsNullOrWhiteSpace(message))
            _message = message;
        return Task.CompletedTask;
    }

    private Task SetVerificationError(string? error)
    {
        if (!string.IsNullOrWhiteSpace(error))
            _error = error;
        return Task.CompletedTask;
    }
}
