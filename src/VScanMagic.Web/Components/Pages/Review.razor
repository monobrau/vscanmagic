@page "/review/{SessionId}"
@rendermode InteractiveServer
@using VScanMagic.Review
@using VScanMagic.Core.Configuration
@using VScanMagic.Core.Models
@using VScanMagic.Core.Risk
@using VScanMagic.Core.Services
@inject IReviewSessionRepository SessionRepo
@inject NavigationManager Nav
@inject RmitPlusSettingsService RmitPlusSettings
@inject VScanMagicOptions Options
@inject SettingsService SettingsSvc

<PageTitle>Review Session</PageTitle>

@if (_session is null)
{
    <p>Loading...</p>
}
else
{
    <div class="d-flex justify-content-between align-items-center mb-3">
        <div>
            <h1>@_session.ClientName</h1>
            <p class="text-muted mb-0">
                Scan: @_session.ScanDate | Presenter: @_session.Presenter | Export set: @ExportSetLabel()
                | Client type: @(_session.IsRmitPlus ? "RMIT+" : "RMIT/CMIT")
            </p>
            @if (!_readOnly)
            {
                <div class="form-check mt-2">
                    <input class="form-check-input" type="checkbox" @bind="_session.IsRmitPlus" @bind:after="OnClientTypeChanged" id="sessionRmitPlus" />
                    <label class="form-check-label" for="sessionRmitPlus">RMIT+ client (affects email and ticket HTML exports)</label>
                </div>
                <div class="mt-2">
                    <button type="button" class="btn btn-outline-secondary btn-sm" @onclick="ApplyOsHostThresholds">
                        Apply OS host thresholds
                    </button>
                    <span class="form-text ms-2">Uses Settings thresholds for Application-scan OS findings only (not Registry, Network, or apps).</span>
                </div>
            }
        </div>
        <div>
            <a class="btn btn-outline-secondary me-2" href="@($"/hostname-review?sessionId={SessionId}")">Host Vuln Counts</a>
            @if (!_readOnly)
            {
                <a class="btn btn-outline-secondary me-2" href="@($"/review/{SessionId}?mode=client")" target="_blank">Open Client View</a>
                <a class="btn btn-success" href="@($"/export/{SessionId}")">Export</a>
            }
            else
            {
                <span class="badge bg-secondary">Read-only client view</span>
            }
        </div>
    </div>

    @if (!string.IsNullOrEmpty(_saveStatus))
    {
        <div class="alert alert-success py-1">@_saveStatus</div>
    }

    @if (GetOrderedFindings().Count == 0)
    {
        <div class="alert alert-warning">
            <strong>No findings in this session.</strong>
            <p class="mb-0 mt-2">
                This usually means review was started from a <strong>Top Ten Data</strong> export instead of the ConnectSecure
                <strong>All Vulnerabilities</strong> XLSX. Go to <a href="/">Ingest</a>, download or upload All Vulnerabilities,
                and start a new review session.
            </p>
            @if (!string.IsNullOrWhiteSpace(_session.SourceFilePath))
            {
                <p class="small text-muted mb-0 mt-2">Source file: @_session.SourceFilePath</p>
            }
        </div>
    }
    else if (!_readOnly)
    {
        <ul class="nav nav-tabs mb-3">
            <li class="nav-item">
                <button type="button" class="nav-link @(_activeTab == ReviewTab ? "active" : "")" @onclick="() => SetActiveTab(ReviewTab)">
                    Findings review
                </button>
            </li>
            <li class="nav-item">
                <button type="button" class="nav-link @(_activeTab == TimeEstimatesTab ? "active" : "")" @onclick="() => SetActiveTab(TimeEstimatesTab)">
                    Time estimates
                </button>
            </li>
        </ul>
    }

    @if (GetOrderedFindings().Count > 0 && (_readOnly || _activeTab == TimeEstimatesTab))
    {
        <div class="card mb-3">
            <div class="card-header d-flex justify-content-between align-items-center">
                <strong>Time estimates — @ExportSetLabel() export set</strong>
                @if (_session.IsRmitPlus)
                {
                    <span class="badge bg-primary">RMIT+ billing fields enabled</span>
                }
            </div>
            <div class="card-body p-0">
                <p class="small text-muted px-3 pt-3 mb-0">
                    Enter hours and billing flags for each export item (grouped like the PowerShell time estimate dialog).
                    Values apply to grouped products such as Visual C++ and .NET variants.
                    Shift-click checkboxes in a column to toggle a range.
                </p>
                <div class="table-responsive">
                    <table class="table table-sm table-hover mb-0 align-middle">
                        <thead class="table-light">
                            <tr>
                                <th>#</th>
                                <th>Product</th>
                                <th class="text-end">Hosts</th>
                                <th style="min-width: 7rem;">Hours</th>
                                <th>After Hours</th>
                                @if (_session.IsRmitPlus)
                                {
                                    <th>3rd Party</th>
                                    <th>Ticket Generated</th>
                                }
                            </tr>
                        </thead>
                        <tbody>
                            @{
                                var timeGroups = GetTimeEstimateGroups();
                            }
                            @for (var gi = 0; gi < timeGroups.Count; gi++)
                            {
                                var row = timeGroups[gi];
                                var rowIndex = gi;
                                var rank = ReviewSessionRanker.GetExportRank(_session, row.SourceFinding);
                                var rowId = GetTimeEstimateRowId(row);
                                <tr>
                                    <td>@(rank?.ToString() ?? "—")</td>
                                    <td class="text-break">@row.GroupKey</td>
                                    <td class="text-end">@row.HostCount</td>
                                    <td>
                                        @if (_readOnly)
                                        {
                                            @row.SourceFinding.TimeEstimateHours
                                        }
                                        else
                                        {
                                            <input class="form-control form-control-sm" type="number" min="0" step="0.25"
                                                   @bind="row.SourceFinding.TimeEstimateHours"
                                                   @bind:after="() => OnTimeEstimateFieldChanged(row.SourceFinding)"
                                                   list="timeEstimatePresets" />
                                        }
                                    </td>
                                    <td class="text-center">
                                        <input class="form-check-input" type="checkbox" disabled="@_readOnly"
                                               checked="@row.SourceFinding.AfterHours"
                                               @onclick="e => OnTimeEstimateCheckboxClick(rowIndex, TimeEstimateCheckbox.AfterHours, e)"
                                               @onclick:preventDefault
                                               id="@($"afterHours-{rowId}")" />
                                    </td>
                                    @if (_session.IsRmitPlus)
                                    {
                                        <td class="text-center">
                                            <input class="form-check-input" type="checkbox" disabled="@_readOnly"
                                                   checked="@row.SourceFinding.ThirdParty"
                                                   @onclick="e => OnTimeEstimateCheckboxClick(rowIndex, TimeEstimateCheckbox.ThirdParty, e)"
                                                   @onclick:preventDefault
                                                   id="@($"thirdParty-{rowId}")" />
                                        </td>
                                        <td class="text-center">
                                            <input class="form-check-input" type="checkbox" disabled="@_readOnly"
                                                   checked="@row.SourceFinding.TicketGenerated"
                                                   @onclick="e => OnTimeEstimateCheckboxClick(rowIndex, TimeEstimateCheckbox.TicketGenerated, e)"
                                                   @onclick:preventDefault
                                                   id="@($"ticketGenerated-{rowId}")" />
                                        </td>
                                    }
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
                @if (!_readOnly)
                {
                    <datalist id="timeEstimatePresets">
                        @foreach (var preset in TimeEstimatePresets)
                        {
                            <option value="@preset"></option>
                        }
                    </datalist>
                }
            </div>
        </div>
    }

    @if (GetOrderedFindings().Count > 0 && (_readOnly || _activeTab == ReviewTab))
    {
    <div class="row">
        <div class="col-md-4">
            @if (_selectedFindingRanks.Count > 1)
            {
                <div class="alert alert-light py-2 small mb-2">
                    <strong>@_selectedFindingRanks.Count</strong> findings selected
                    <div class="btn-group btn-group-sm ms-2">
                        <button type="button" class="btn btn-outline-secondary" @onclick="() => BulkSetFindingExport(true)">Include in export</button>
                        <button type="button" class="btn btn-outline-secondary" @onclick="() => BulkSetFindingExport(false)">Exclude from export</button>
                    </div>
                </div>
            }
            <div class="list-group">
                @foreach (var f in GetOrderedFindings())
                {
                    var exportRank = ReviewSessionRanker.GetExportRank(_session, f);
                    <button type="button"
                            class="list-group-item list-group-item-action @(IsFindingSelected(f) ? "active" : "") @FindingListClass(f)"
                            @onclick="e => OnFindingClick(f, e)">
                        <div class="d-flex justify-content-between align-items-start gap-2">
                            <div class="flex-grow-1 text-break">
                                @if (exportRank.HasValue)
                                {
                                    <strong>@exportRank.</strong>@(" ")@f.Product
                                }
                                else if (IsReserveFinding(f))
                                {
                                    <span class="text-muted">#@f.OriginalRank @f.Product</span>
                                    <span class="badge bg-light text-dark ms-1">Reserve</span>
                                }
                                else if (f.ExcludedFromExport)
                                {
                                    <span class="text-muted"><s>#@f.OriginalRank @f.Product</s></span>
                                    <span class="badge bg-secondary ms-1">Excluded</span>
                                }
                            </div>
                            <span class="badge bg-dark flex-shrink-0">@f.RiskScore.ToString("N2")</span>
                        </div>
                        <small class="d-block mt-1">@f.Status · @IncludedHostCount(f) host(s)@FormatFindingBadges(f)</small>
                    </button>
                }
            </div>
            @if (!_readOnly)
            {
                <div class="form-text mt-2">Shift-click findings to select a range.</div>
            }
        </div>
        <div class="col-md-8">
            @if (_selected is not null)
            {
                <div class="card">
                    <div class="card-header">
                        <div>
                            <strong>@FormatFindingTitle(_selected)</strong> (@_selected.Source)
                            @if (!_readOnly)
                            {
                                <div class="form-check mt-2 mb-0">
                                    <input class="form-check-input" type="checkbox" checked="@_selected.IncludeInExport"
                                           @onchange="e => SetFindingExport(e.Value is true)" id="includeExport" />
                                    <label class="form-check-label" for="includeExport">Include finding in export</label>
                                </div>
                                <div class="form-text">Uncheck to drop this item — the next ranked vulnerability promotes into the export set (@ExportSetLabel()). Document why with Status and Meeting Notes.</div>
                            }
                            else if (!_selected.IncludeInExport || _selected.ExcludedFromExport)
                            {
                                <span class="badge bg-secondary mt-1">Excluded from export</span>
                            }
                        </div>
                    </div>
                    <div class="card-body">
                        <p>Risk: @_selected.RiskScore.ToString("N2") | EPSS: @_selected.Epss.ToString("N4") | CVSS: @_selected.AvgCvss.ToString("N2") | Vulns: @_selected.VulnCount</p>

                        @if (!_readOnly)
                        {
                            <div class="mb-3 border rounded p-3 bg-light">
                                <label class="form-label mb-2">Time estimate &amp; billing</label>
                                <div class="row g-2 align-items-end">
                                    <div class="col-sm-4">
                                        <label class="form-label small mb-1" for="timeEstimateHours">Hours</label>
                                        <input id="timeEstimateHours" class="form-control form-control-sm" type="number" min="0" step="0.25"
                                               @bind="_selected.TimeEstimateHours" @bind:after="OnTimeEstimateFieldChanged" list="timeEstimatePresetsDetail" />
                                        <datalist id="timeEstimatePresetsDetail">
                                            @foreach (var preset in TimeEstimatePresets)
                                            {
                                                <option value="@preset"></option>
                                            }
                                        </datalist>
                                    </div>
                                    <div class="col-sm-8">
                                        <div class="form-check">
                                            <input class="form-check-input" type="checkbox" @bind="_selected.AfterHours" @bind:after="OnTimeEstimateFieldChanged" id="afterHoursDetail" />
                                            <label class="form-check-label" for="afterHoursDetail">After Hours</label>
                                        </div>
                                        @if (_session.IsRmitPlus)
                                        {
                                            <div class="form-check">
                                                <input class="form-check-input" type="checkbox" @bind="_selected.ThirdParty" @bind:after="OnTimeEstimateFieldChanged" id="thirdPartyDetail" />
                                                <label class="form-check-label" for="thirdPartyDetail">3rd party application (not covered by RMIT+ flat rate)</label>
                                            </div>
                                            <div class="form-check">
                                                <input class="form-check-input" type="checkbox" @bind="_selected.TicketGenerated" @bind:after="OnTimeEstimateFieldChanged" id="ticketGeneratedDetail" />
                                                <label class="form-check-label" for="ticketGeneratedDetail">Ticket already generated</label>
                                            </div>
                                        }
                                    </div>
                                </div>
                                <div class="form-text mt-2">
                                    Same fields as the <button type="button" class="btn btn-link btn-sm p-0 align-baseline" @onclick="() => SetActiveTab(TimeEstimatesTab)">Time estimates</button> tab.
                                    Applies to grouped products (Visual C++, .NET, etc.).
                                </div>
                            </div>
                            <div class="mb-3">
                                <div class="d-flex justify-content-between align-items-center mb-2">
                                    <label class="form-label mb-0">Affected systems</label>
                                    <div class="btn-group btn-group-sm">
                                        <button type="button" class="btn btn-outline-secondary" @onclick="SelectAllHosts">Select all</button>
                                        <button type="button" class="btn btn-outline-secondary" @onclick="DeselectAllHosts">Deselect all</button>
                                    </div>
                                </div>
                                @if ((_selected.AffectedSystems ?? []).Count == 0)
                                {
                                    <p class="text-muted small mb-0">No per-host breakdown for this finding.</p>
                                }
                                else
                                {
                                    <div class="table-responsive border rounded" style="max-height: 260px; overflow-y: auto;">
                                        <table class="table table-sm table-hover mb-0">
                                            <thead class="table-light sticky-top">
                                                <tr>
                                                    <th style="width: 2.5rem;">Include</th>
                                                    <th>Host</th>
                                                    <th>IP</th>
                                                    <th class="text-end">Vulns</th>
                                                </tr>
                                            </thead>
                                            <tbody>
                                                @foreach (var s in (_selected.AffectedSystems ?? []).OrderByDescending(x => x.VulnCount))
                                                {
                                                    <tr class="@(IsHostIncluded(s) ? "" : "table-secondary text-muted")">
                                                        <td>
                                                            <input class="form-check-input" type="checkbox" checked="@IsHostIncluded(s)"
                                                                   @onclick="e => OnHostCheckboxClick(s, e)" @onclick:preventDefault />
                                                        </td>
                                                        <td>@(string.IsNullOrWhiteSpace(s.HostName) ? "—" : s.HostName)</td>
                                                        <td>@s.Ip</td>
                                                        <td class="text-end">@s.VulnCount</td>
                                                    </tr>
                                                }
                                            </tbody>
                                        </table>
                                    </div>
                                    <div class="form-text">
                                        Uncheck hosts to omit from exports. Shift-click to toggle a range.
                                        @if (_selected is not null && OsHostVulnThresholdHelper.HasActiveThreshold(_userSettings, _selected.Product, _selected.Source))
                                        {
                                            <span> OS threshold: hosts below @GetOsThresholdLabel(_selected) vulns are excluded.</span>
                                        }
                                    </div>
                                }
                            </div>
                        }
                        else
                        {
                            <p><strong>Affected:</strong> @FormatAffectedSystems(_selected)</p>
                        }

                        @if (_readOnly)
                        {
                            @if (_selected.TimeEstimateHours > 0 || _selected.AfterHours || (_session.IsRmitPlus && (_selected.ThirdParty || _selected.TicketGenerated)))
                            {
                                <p>
                                    <strong>Time estimate:</strong>
                                    @if (_selected.TimeEstimateHours > 0)
                                    {
                                        <span>@_selected.TimeEstimateHours hour(s)</span>
                                    }
                                    else
                                    {
                                        <span>—</span>
                                    }
                                    @if (_selected.AfterHours)
                                    {
                                        <span class="badge bg-secondary ms-1">After Hours</span>
                                    }
                                    @if (_session.IsRmitPlus && _selected.ThirdParty)
                                    {
                                        <span class="badge bg-warning text-dark ms-1">3rd Party</span>
                                    }
                                    @if (_session.IsRmitPlus && TimeEstimateModifierHelper.IsTicketGenerated(_selected.AfterHours, _selected.TicketGenerated, _selected.ThirdParty))
                                    {
                                        <span class="badge bg-info text-dark ms-1">Ticket Generated</span>
                                    }
                                </p>
                            }
                            <p><strong>Status:</strong> @_selected.Status</p>
                            <p><strong>Remediation:</strong></p>
                            <p>@(_selected.RevisedRemediation)</p>
                            @if (!string.IsNullOrWhiteSpace(_selected.MeetingNotes))
                            {
                                <p><strong>Notes:</strong> @_selected.MeetingNotes</p>
                            }
                            @if ((_selected.Tasks ?? []).Count > 0)
                            {
                                <ul>
                                    @foreach (var t in _selected.Tasks ?? [])
                                    {
                                        <li>@t.Text</li>
                                    }
                                </ul>
                            }
                        }
                        else
                        {
                            <div class="mb-3">
                                <label class="form-label">Status</label>
                                <select class="form-select" @bind="_selected.Status" @bind:after="ScheduleSave">
                                    @foreach (FindingStatus s in Enum.GetValues<FindingStatus>())
                                    {
                                        <option value="@s">@s</option>
                                    }
                                </select>
                            </div>
                            <div class="mb-3">
                                <label class="form-label">Revised Remediation</label>
                                <textarea class="form-control" rows="6" @bind="_selected.RevisedRemediation" @bind:after="ScheduleSave"></textarea>
                            </div>
                            <div class="mb-3">
                                <label class="form-label">Meeting Notes</label>
                                <textarea class="form-control" rows="3" @bind="_selected.MeetingNotes" @bind:after="ScheduleSave"></textarea>
                            </div>
                            <div class="mb-3">
                                <label class="form-label">Tasks (one per line)</label>
                                <textarea class="form-control" rows="3" @bind="_tasksText" @bind:after="UpdateTasks"></textarea>
                            </div>
                        }

                        @if (!_readOnly && !string.IsNullOrWhiteSpace(_selected.OriginalFix))
                        {
                            <details class="mt-3">
                                <summary>ConnectSecure patch reference</summary>
                                <p class="small text-muted mb-1">Patch/version details from the scan. Exported as ConnectSecure Solution when distinct from remediation guidance.</p>
                                <p class="small mb-0">@_selected.OriginalFix</p>
                            </details>
                        }
                    </div>
                </div>
            }
        </div>
    </div>
    }
}

@code {
    private const string ReviewTab = "review";
    private const string TimeEstimatesTab = "time";

    private static readonly decimal[] TimeEstimatePresets = [0.25m, 0.5m, 0.75m, 1m, 1.5m, 2m, 2.5m, 3m, 4m, 5m, 6m, 8m];

    [Parameter] public string SessionId { get; set; } = "";
    [SupplyParameterFromQuery] public string? Mode { get; set; }

    private ReviewSession? _session;
    private ReviewFinding? _selected;
    private UserSettings _userSettings = new();
    private bool _readOnly;
    private string _activeTab = ReviewTab;
    private string? _saveStatus;
    private string _tasksText = "";
    private CancellationTokenSource? _saveCts;
    private HashSet<int> _selectedFindingRanks = [];
    private int? _findingAnchorRank;
    private readonly CheckboxRangeColumn _hostIncludeRange = new();
    private readonly CheckboxRangeColumn _afterHoursRange = new();
    private readonly CheckboxRangeColumn _thirdPartyRange = new();
    private readonly CheckboxRangeColumn _ticketGeneratedRange = new();

    private enum TimeEstimateCheckbox { AfterHours, ThirdParty, TicketGenerated }

    protected override async Task OnParametersSetAsync()
    {
        _readOnly = string.Equals(Mode, "client", StringComparison.OrdinalIgnoreCase);
        _userSettings = SettingsSvc.LoadUserSettings();
        _session = await SessionRepo.GetAsync(SessionId);
        if (_session is not null)
        {
            _session.Findings ??= [];
            var beforeProducts = _session.Findings.Select(f => f.Product).ToList();
            var beforeFixes = _session.Findings.Select(f => f.OriginalFix).ToList();
            var hadCveData = _session.Findings.Any(f =>
                !string.IsNullOrWhiteSpace(f.CveIds) || CveReferenceHelper.IsCveOnlyProduct(f.Product));
            ReviewSessionRanker.EnsureLegacyFields(_session, Options);
            var namesChanged = _session.Findings.Zip(beforeProducts, (after, prior) =>
                !string.Equals(after.Product, prior, StringComparison.Ordinal)).Any(changed => changed);
            var fixesChanged = _session.Findings.Zip(beforeFixes, (after, prior) =>
                !string.Equals(after.OriginalFix, prior, StringComparison.Ordinal)).Any(changed => changed);
            if ((namesChanged || fixesChanged || hadCveData) && !_readOnly)
                await SessionRepo.SaveAsync(_session);
            if (_session.Findings.Count > 0)
            {
                var first = _session.Findings.OrderBy(f => f.OriginalRank).First();
                _selectedFindingRanks = [first.OriginalRank];
                _findingAnchorRank = first.OriginalRank;
                SelectFinding(first);
            }
        }
    }

    private List<ReviewFinding> GetOrderedFindings() =>
        (_session?.Findings ?? []).OrderBy(x => x.OriginalRank).ToList();

    private bool IsFindingSelected(ReviewFinding finding) =>
        _selectedFindingRanks.Contains(finding.OriginalRank);

    private void OnFindingClick(ReviewFinding finding, MouseEventArgs e)
    {
        if (_session is null) return;

        var ordered = GetOrderedFindings();
        var ranks = ordered.Select(f => f.OriginalRank).ToList();
        var index = ranks.IndexOf(finding.OriginalRank);
        if (index < 0) return;

        if (e.ShiftKey && _findingAnchorRank is int anchorRank)
        {
            var anchorIndex = ranks.IndexOf(anchorRank);
            if (anchorIndex >= 0)
            {
                var start = Math.Min(anchorIndex, index);
                var end = Math.Max(anchorIndex, index);
                _selectedFindingRanks.Clear();
                for (var i = start; i <= end; i++)
                    _selectedFindingRanks.Add(ranks[i]);
            }
        }
        else
        {
            _selectedFindingRanks.Clear();
            _selectedFindingRanks.Add(finding.OriginalRank);
            _findingAnchorRank = finding.OriginalRank;
        }

        _hostIncludeRange.Reset();
        SelectFinding(finding);
    }

    private void BulkSetFindingExport(bool include)
    {
        if (_session is null || _selectedFindingRanks.Count == 0) return;

        foreach (var finding in _session.Findings.Where(f => _selectedFindingRanks.Contains(f.OriginalRank)))
        {
            finding.IncludeInExport = include;
            finding.ExcludedFromExport = !include;
        }

        ReviewSessionRanker.Rebalance(_session);
        ScheduleSave();
    }

    private string ExportSetLabel()
    {
        if (_session is null) return "";
        return _session.ExportTopN <= 0
            ? "All"
            : $"Top {_session.ExportTopN}";
    }

    private string FormatFindingTitle(ReviewFinding finding)
    {
        if (_session is null) return finding.Product;
        var exportRank = ReviewSessionRanker.GetExportRank(_session, finding);
        return exportRank.HasValue
            ? $"{exportRank}. {finding.Product}"
            : $"#{finding.OriginalRank} {finding.Product}";
    }

    private bool IsReserveFinding(ReviewFinding finding) =>
        _session is not null &&
        !finding.IncludeInExport &&
        !finding.ExcludedFromExport;

    private void SetFindingExport(bool include)
    {
        if (_selected is null || _session is null) return;
        _selected.IncludeInExport = include;
        _selected.ExcludedFromExport = !include;
        ReviewSessionRanker.Rebalance(_session);
        ScheduleSave();
    }

    private void SelectFinding(ReviewFinding f)
    {
        _selected = f;
        f.Tasks ??= [];
        f.AffectedSystems ??= [];
        _tasksText = string.Join(Environment.NewLine, f.Tasks.Select(t => t.Text));
        _hostIncludeRange.Reset();
    }

    private static string FormatAffectedSystems(ReviewFinding finding) =>
        FindingExportDetails.FormatAffectedSystemsInline(finding);

    private static string FindingListClass(ReviewFinding finding) =>
        finding.IncludeInExport ? "" : "opacity-75";

    private static string IncludedHostCount(ReviewFinding finding)
    {
        var systems = finding.AffectedSystems ?? [];
        if (systems.Count == 0) return "0";
        var included = systems.Count(s => !s.ExcludedFromExport);
        return included == systems.Count ? included.ToString() : $"{included}/{systems.Count}";
    }

    private static bool IsHostIncluded(ReviewAffectedSystem system) => !system.ExcludedFromExport;

    private List<ReviewAffectedSystem> GetOrderedHosts() =>
        (_selected?.AffectedSystems ?? []).OrderByDescending(x => x.VulnCount).ToList();

    private static int FindHostIndex(ReviewAffectedSystem system, IReadOnlyList<ReviewAffectedSystem> hosts)
    {
        for (var i = 0; i < hosts.Count; i++)
        {
            if (HostKey(hosts[i]) == HostKey(system))
                return i;
        }

        return -1;
    }

    private static string HostKey(ReviewAffectedSystem system) =>
        $"{system.HostName}|{system.Ip}|{system.Username}";

    private void OnHostCheckboxClick(ReviewAffectedSystem system, MouseEventArgs e)
    {
        var hosts = GetOrderedHosts();
        var index = FindHostIndex(system, hosts);
        if (index < 0) return;

        _hostIncludeRange.Click(index, !IsHostIncluded(system), e, (i, on) => SetHostIncluded(hosts[i], on));
        ScheduleSave();
    }

    private static void SetHostIncluded(ReviewAffectedSystem system, bool included) =>
        system.ExcludedFromExport = !included;

    private void SelectAllHosts()
    {
        if (_selected?.AffectedSystems is null) return;
        foreach (var s in _selected.AffectedSystems)
            s.ExcludedFromExport = false;
        _hostIncludeRange.Reset();
        ScheduleSave();
    }

    private void DeselectAllHosts()
    {
        if (_selected?.AffectedSystems is null) return;
        foreach (var s in _selected.AffectedSystems)
            s.ExcludedFromExport = true;
        _hostIncludeRange.Reset();
        ScheduleSave();
    }

    private CheckboxRangeColumn TimeEstimateRangeFor(TimeEstimateCheckbox field) => field switch
    {
        TimeEstimateCheckbox.AfterHours => _afterHoursRange,
        TimeEstimateCheckbox.ThirdParty => _thirdPartyRange,
        TimeEstimateCheckbox.TicketGenerated => _ticketGeneratedRange,
        _ => _afterHoursRange
    };

    private static bool GetTimeEstimateCheckbox(TimeEstimateGroupRow row, TimeEstimateCheckbox field) => field switch
    {
        TimeEstimateCheckbox.AfterHours => row.SourceFinding.AfterHours,
        TimeEstimateCheckbox.ThirdParty => row.SourceFinding.ThirdParty,
        TimeEstimateCheckbox.TicketGenerated => row.SourceFinding.TicketGenerated,
        _ => false
    };

    private void SetTimeEstimateCheckbox(TimeEstimateGroupRow row, TimeEstimateCheckbox field, bool value)
    {
        switch (field)
        {
            case TimeEstimateCheckbox.AfterHours:
                row.SourceFinding.AfterHours = value;
                break;
            case TimeEstimateCheckbox.ThirdParty:
                row.SourceFinding.ThirdParty = value;
                break;
            case TimeEstimateCheckbox.TicketGenerated:
                row.SourceFinding.TicketGenerated = value;
                break;
        }
    }

    private void OnTimeEstimateCheckboxClick(int rowIndex, TimeEstimateCheckbox field, MouseEventArgs e)
    {
        var groups = GetTimeEstimateGroups();
        if (rowIndex < 0 || rowIndex >= groups.Count)
            return;

        var row = groups[rowIndex];
        var newValue = !GetTimeEstimateCheckbox(row, field);
        TimeEstimateRangeFor(field).Click(rowIndex, newValue, e, (i, on) =>
        {
            var target = groups[i];
            SetTimeEstimateCheckbox(target, field, on);
            OnTimeEstimateFieldChanged(target.SourceFinding);
        });
    }

    private void UpdateTasks()
    {
        if (_selected is null) return;
        _selected.Tasks = _tasksText
            .Split(['\r', '\n'], StringSplitOptions.RemoveEmptyEntries)
            .Select(line => new ReviewTask { Text = line.Trim() })
            .Where(t => !string.IsNullOrWhiteSpace(t.Text))
            .ToList();
        ScheduleSave();
    }

    private void OnTimeEstimateFieldChanged()
    {
        if (_session is null || _selected is null) return;
        OnTimeEstimateFieldChanged(_selected);
    }

    private void OnTimeEstimateFieldChanged(ReviewFinding finding)
    {
        if (_session is null) return;
        if (finding.TimeEstimateHours < 0)
            finding.TimeEstimateHours = 0;
        ReviewFindingTimeEstimate.ApplyToGroup(_session, finding);
        ScheduleSave();
    }

    private void SetActiveTab(string tab)
    {
        _activeTab = tab;
    }

    private IReadOnlyList<TimeEstimateGroupRow> GetTimeEstimateGroups() =>
        _session is null ? [] : ReviewFindingTimeEstimate.GetExportGroups(_session);

    private static string GetTimeEstimateRowId(TimeEstimateGroupRow row) =>
        row.GroupKey.Replace(' ', '-').Replace('.', '-').ToLowerInvariant();

    private string FormatFindingBadges(ReviewFinding finding)
    {
        if (_session is null) return "";
        var parts = new List<string>();
        if (finding.TimeEstimateHours > 0)
            parts.Add($" · {finding.TimeEstimateHours}h");
        if (finding.AfterHours)
            parts.Add(" · After Hours");
        if (_session.IsRmitPlus && finding.ThirdParty)
            parts.Add(" · 3rd Party");
        if (_session.IsRmitPlus && finding.TicketGenerated)
            parts.Add(" · Ticket");
        return string.Concat(parts);
    }

    private void OnClientTypeChanged()
    {
        if (_session is null) return;
        RmitPlusSettings.Set(_session.ClientName, _session.IsRmitPlus);
        ReviewFindingTimeEstimate.EnsureDefaults(_session);
        ScheduleSave();
    }

    private async Task ApplyOsHostThresholds()
    {
        if (_session is null || _readOnly) return;
        _userSettings = SettingsSvc.LoadUserSettings();
        HostOsThresholdApplier.Apply(_session, _userSettings);
        await SessionRepo.SaveAsync(_session);
        _saveStatus = $"Applied OS host thresholds {DateTime.Now:HH:mm:ss}";
        await InvokeAsync(StateHasChanged);
    }

    private string GetOsThresholdLabel(ReviewFinding finding)
    {
        var category = OsHostVulnThresholdHelper.ClassifyProduct(finding.Product);
        return OsHostVulnThresholdHelper.GetThreshold(_userSettings, category).ToString();
    }

    private void ScheduleSave()
    {
        if (_readOnly || _session is null) return;
        _saveCts?.Cancel();
        _saveCts = new CancellationTokenSource();
        _ = SaveDebouncedAsync(_saveCts.Token);
    }

    private async Task SaveDebouncedAsync(CancellationToken ct)
    {
        try
        {
            await Task.Delay(500, ct);
            if (_session is null) return;
            await SessionRepo.SaveAsync(_session, ct);
            _saveStatus = $"Saved {DateTime.Now:HH:mm:ss}";
            await InvokeAsync(StateHasChanged);
        }
        catch (TaskCanceledException) { }
    }
}
