    {
        if (_session is null) return;
        RmitPlusSettings.Set(_session.ClientName, _session.IsRmitPlus);
        ReviewFindingTimeEstimate.EnsureDefaults(_session);
        ScheduleSave();
    }

    private async Task ApplyOsHostThresholds()
    {
        if (_session is null) return;
        _userSettings = SettingsSvc.LoadUserSettings();
        HostOsThresholdApplier.Apply(_session, _userSettings);
        await SessionRepo.SaveAsync(_session);
        _saveStatus = $"Applied OS host thresholds {DateTime.Now:HH:mm:ss}";
        await InvokeAsync(StateHasChanged);
    }

    private async Task RefreshUsernamesAsync()
    {
        if (_session is null)
            return;

        _usernameRefreshError = null;
        if (!TryGetCompanyId(out var companyId))
        {
            _usernameRefreshError = "Set a ConnectSecure company ID on this session to refresh usernames.";
            return;
        }

        _usernameRefreshBusy = true;
        try
        {
            var result = await UsernameRefresh.RefreshSessionAsync(_session, companyId, exportFindingsOnly: false);
            if (result.Status == ReviewUsernameRefreshStatus.NoEmptyUsernames)
            {
                _usernameRefreshError = "All hosts already have usernames.";
                return;
            }

            if (result.Status == ReviewUsernameRefreshStatus.Skipped && !string.IsNullOrWhiteSpace(result.Error))
            {
                _usernameRefreshError = result.Error;
                return;
            }

            if (result.UsernamesFilled > 0)
                await SessionRepo.SaveAsync(_session);

            RefreshFindingCaches();
            _saveStatus = result.UsernamesFilled > 0
                ? $"Refreshed usernames: filled {result.UsernamesFilled} host(s) from ConnectSecure ({result.LookupMatches} matched of {result.HostnamesRequested} requested) at {DateTime.Now:HH:mm:ss}"
                : $"Username refresh complete: no new usernames to fill ({result.LookupMatches} matched of {result.HostnamesRequested} hosts) at {DateTime.Now:HH:mm:ss}";
        }
        catch (Exception ex)
        {
            _usernameRefreshError = ex.Message;
        }
        finally
        {
            _usernameRefreshBusy = false;
            await InvokeAsync(StateHasChanged);
        }
    }

    private string GetOsThresholdLabel(ReviewFinding finding)
    {
        var category = OsHostVulnThresholdHelper.ClassifyProduct(finding.Product);
        return OsHostVulnThresholdHelper.GetThreshold(_userSettings, category).ToString();
    }

    private void ScheduleSave()
    {
        if (_session is null) return;
        RefreshFindingCaches();
        _saveCts?.Cancel();
        _saveCts = new CancellationTokenSource();
        _ = SaveDebouncedAsync(_saveCts.Token);
    }

    private async Task SaveDebouncedAsync(CancellationToken ct)
    {
        try
        {
            await Task.Delay(1500, ct);
            if (_session is null) return;
            await SessionRepo.SaveAsync(_session, ct);
            _saveStatus = $"Saved {DateTime.Now:HH:mm:ss}";
            await InvokeAsync(StateHasChanged);
        }
        catch (TaskCanceledException) { }
    }

    private IReadOnlyList<string> GetSelectedCveIds() =>
        _selected is null ? [] : FindingExportDetails.GetCveIds(_selected);

    private static bool ShouldShowCveSection(ReviewFinding? finding)
    {
        if (finding is null)
            return false;

        if (CveOnlyFindingDisplay.IsCveOnlyFinding(finding))
            return true;

        var count = FindingExportDetails.GetCveIds(finding).Count;
        return count > 0 && count <= MaxDisplayedCveLinks;
    }

    private async Task FetchNvdForSelected()
    {
        if (_session is null || _selected is null)
            return;

        _nvdBusy = true;
        _nvdStatus = null;
        try
        {
            var updated = await CveEnrichment.EnrichFindingAsync(_selected, _userSettings, applyToRemediation: true);
            if (updated)
            {
                await SessionRepo.SaveAsync(_session);
                _nvdStatus = "NVD details applied to this finding.";
                _saveStatus = $"Saved {DateTime.Now:HH:mm:ss}";
            }
            else
            {
                _nvdStatus = "No NVD summary returned for these CVE IDs.";
            }
        }
        catch (Exception ex)
        {
            _nvdStatus = ex.Message;
        }
        finally
        {
            _nvdBusy = false;
        }
    }

    private async Task AutoEnrichMissingAsync()
    {
        if (_session is null || _nvdBusy || !_userSettings.NvdEnrichOnIngest)
            return;

        if (!_session.Findings.Any(f => f.IncludeInExport && CveEnrichmentPolicy.ShouldEnrich(f)))
            return;

        _nvdBusy = true;
        try
        {
            var count = await CveEnrichment.EnrichMissingExportAsync(_session, _userSettings);
            if (count > 0)
            {
                await SessionRepo.SaveAsync(_session);
                _saveStatus = $"Fetched NVD details for {count} finding(s) at {DateTime.Now:HH:mm:ss}";
                await InvokeAsync(StateHasChanged);
            }
        }
        catch (Exception ex)
        {
            _nvdStatus = ex.Message;
            await InvokeAsync(StateHasChanged);
        }
        finally
        {
            _nvdBusy = false;
        }
    }
