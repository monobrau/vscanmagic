@page "/review/{SessionId}"
@rendermode InteractiveServer
@using VScanMagic.Review
@using VScanMagic.Review.Services
@using VScanMagic.Core.Configuration
@using VScanMagic.Core.Models
@using VScanMagic.Core.Risk
@using VScanMagic.Core.Services
@using VScanMagic.ConnectSecure
@inject IReviewSessionRepository SessionRepo
@inject NavigationManager Nav
@inject RmitPlusSettingsService RmitPlusSettings
@inject VScanMagicOptions Options
@inject SettingsService SettingsSvc
@inject CveEnrichmentService CveEnrichment
@inject ConnectSecureClient ConnectSecure
@inject ConnectSecurePatchService PatchService
@inject ConnectSecureReviewSuppressService ReviewSuppress
@inject ReviewUsernameRefreshService UsernameRefresh

<PageTitle>Review Session</PageTitle>

@if (_session is null)
{
    <p>Loading...</p>
}
else
{
    <div class="d-flex justify-content-between align-items-center mb-3">
        <div>
            <h1>@_session.ClientName <HelpTip Text="Live review session. Use Deliverables for copy-paste client content and Export for report files." AlignEnd="true" /></h1>
            <p class="text-muted mb-0">
                Scan: @_session.ScanDate | Presenter: @_session.Presenter | Export set: @ExportSetLabel()
                | Client type: @(_session.IsRmitPlus ? "RMIT+" : "RMIT/CMIT")
            </p>
            <div class="form-check mt-2">
                <input class="form-check-input" type="checkbox" @bind="_session.IsRmitPlus" @bind:after="OnClientTypeChanged" id="sessionRmitPlus" />
                <label class="form-check-label" for="sessionRmitPlus">RMIT+ client (affects email and ticket HTML exports)</label>
            </div>
            <div class="mt-2 d-flex flex-wrap align-items-center gap-2">
                <button type="button" class="btn btn-outline-secondary btn-sm" @onclick="ApplyOsHostThresholds">
                    Apply OS host thresholds
                </button>
                <button type="button" class="btn btn-outline-secondary btn-sm" disabled="@_usernameRefreshBusy" @onclick="RefreshUsernamesAsync">
                    @(_usernameRefreshBusy ? "Refreshing usernames…" : "Refresh usernames")
                </button>
                <span class="form-text">
                    OS thresholds: Application-scan OS findings only.
                    Usernames: ConnectSecure logged-in user per host (fills blanks only).
                </span>
            </div>
            @if (!TryGetCompanyId(out _))
            {
                <p class="form-text text-warning mb-0">Set company ID below to refresh usernames from ConnectSecure during the client call.</p>
            }
        </div>
        <div>
            <a class="btn btn-outline-secondary me-2" href="@($"/hostname-review?sessionId={SessionId}")">Host Vuln Counts</a>
            <button type="button" class="btn btn-outline-secondary me-2" disabled="@_usernameRefreshBusy" @onclick="RefreshUsernamesAsync">
                @(_usernameRefreshBusy ? "Refreshing…" : "Refresh usernames")
            </button>
            <a class="btn btn-outline-primary me-2" href="@($"/review/{SessionId}/deliverables")">Deliverables <HelpTip Text="Copy ticket instructions, email (paste OneDrive links here), time estimate, and Manage PSA notes." /></a>
            <a class="btn btn-success" href="@($"/export/{SessionId}")">Export</a>
        </div>
    </div>

    @if (!string.IsNullOrEmpty(_saveStatus))
    {
        <div class="alert alert-success py-1">@_saveStatus</div>
    }
    @if (!string.IsNullOrEmpty(_usernameRefreshError))
    {
        <div class="alert alert-danger py-1">@_usernameRefreshError</div>
    }

    @if (_orderedFindings.Count == 0)
    {
        <div class="alert alert-warning">
            <strong>No findings in this session.</strong>
            <p class="mb-0 mt-2">
                This usually means review was started from a <strong>Top Ten Data</strong> export instead of the ConnectSecure
                <strong>All Vulnerabilities</strong> XLSX. Go to <a href="/">Ingest</a>, download or upload All Vulnerabilities,
                and start a new review session.
            </p>
            @if (!string.IsNullOrWhiteSpace(_session.SourceFilePath))
            {
                <p class="small text-muted mb-0 mt-2">Source file: @_session.SourceFilePath</p>
            }
        </div>
    }
    else
    {
        <ul class="nav nav-tabs mb-3">
            <li class="nav-item">
                <button type="button" class="nav-link @(_activeTab == ReviewTab ? "active" : "")" @onclick="() => SetActiveTab(ReviewTab)">
                    Findings review <HelpTip Text="Walk the export set with the client — edit remediation, notes, hosts, and ConnectSecure suppress." />
                </button>
            </li>
            <li class="nav-item">
                <button type="button" class="nav-link @(_activeTab == AddToExportTab ? "active" : "")" @onclick="() => SetActiveTab(AddToExportTab)">
                    Add to export (@CandidateCount()) <HelpTip Text="Findings not in the initial client report — network, registry, and overflow application items." />
                </button>
            </li>
            <li class="nav-item">
                <button type="button" class="nav-link @(_activeTab == TimeEstimatesTab ? "active" : "")" @onclick="() => SetActiveTab(TimeEstimatesTab)">
                    Time estimates
                </button>
            </li>
        </ul>
    }

    @if (_orderedFindings.Count > 0 && _activeTab == TimeEstimatesTab)
    {
        <div class="card mb-3">
            <div class="card-header d-flex justify-content-between align-items-center">
                <strong>Time estimates — @ExportSetLabel() export set</strong>
                @if (_session.IsRmitPlus)
                {
                    <span class="badge bg-primary">RMIT+ billing fields enabled</span>
                }
            </div>
            <div class="card-body p-0">
                <p class="small text-muted px-3 pt-3 mb-0">
                    Enter estimated hours and billing options for each item in the client report.
                    Grouped products (Visual C++, .NET, etc.) share one row.
                    <strong>After hours</strong> — work billed outside normal business hours.
                    Shift-click checkboxes in a column to toggle a range.
                </p>
                <div class="table-responsive">
                    <table class="table table-sm table-hover mb-0 align-middle">
                        <thead class="table-light">
                            <tr>
                                <th>#</th>
                                <th>Product</th>
                                <th class="text-end">Hosts</th>
                                <th style="min-width: 7rem;">Hours</th>
                                <th>After hours</th>
                                @if (_session.IsRmitPlus)
                                {
                                    <th>Third party</th>
                                    <th>Ticket created</th>
                                }
                            </tr>
                        </thead>
                        <tbody>
                            @{
                                var timeGroups = _timeEstimateGroups;
                            }
                            @for (var gi = 0; gi < timeGroups.Count; gi++)
                            {
                                var row = timeGroups[gi];
                                var rowIndex = gi;
                                var rank = ReviewSessionRanker.GetExportRank(_session, row.SourceFinding);
                                var rowId = GetTimeEstimateRowId(row);
                                <tr>
                                    <td>@(rank?.ToString() ?? "—")</td>
                                    <td class="text-break">@row.GroupKey</td>
                                    <td class="text-end">@row.HostCount</td>
                                    <td>
                                        <input class="form-control form-control-sm" type="number" min="0" step="0.25"
                                               @bind="row.SourceFinding.TimeEstimateHours"
                                               @bind:after="() => OnTimeEstimateFieldChanged(row.SourceFinding)"
                                               list="timeEstimatePresets" />
                                    </td>
                                    <td class="text-center">
                                        <input class="form-check-input" type="checkbox"
                                               checked="@row.SourceFinding.AfterHours"
                                               @onclick="e => OnTimeEstimateCheckboxClick(rowIndex, TimeEstimateCheckbox.AfterHours, e)"
                                               @onclick:preventDefault
                                               id="@($"afterHours-{rowId}")" />
                                    </td>
                                    @if (_session.IsRmitPlus)
                                    {
                                        <td class="text-center">
                                            <input class="form-check-input" type="checkbox"
                                                   checked="@row.SourceFinding.ThirdParty"
                                                   @onclick="e => OnTimeEstimateCheckboxClick(rowIndex, TimeEstimateCheckbox.ThirdParty, e)"
                                                   @onclick:preventDefault
                                                   id="@($"thirdParty-{rowId}")" />
                                        </td>
                                        <td class="text-center">
                                            <input class="form-check-input" type="checkbox"
                                                   checked="@row.SourceFinding.TicketGenerated"
                                                   @onclick="e => OnTimeEstimateCheckboxClick(rowIndex, TimeEstimateCheckbox.TicketGenerated, e)"
                                                   @onclick:preventDefault
                                                   id="@($"ticketGenerated-{rowId}")" />
                                        </td>
                                    }
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
                <datalist id="timeEstimatePresets">
                    @foreach (var preset in TimeEstimatePresets)
                    {
                        <option value="@preset"></option>
                    }
                </datalist>
            </div>
        </div>
    }

    @if (GetOrderedFindings().Count > 0 && _activeTab == AddToExportTab)
    {
        <div class="alert alert-info py-2">
            Network and registry findings are not included in the initial Top @_session.ExportTopN report list.
            Review the items below and add any that should go to the client.
            Application findings below that cutoff are listed here as well.
        </div>

        <div class="btn-group btn-group-sm mb-3">
            <button type="button" class="btn @CandidateFilterClass(null)" @onclick="() => SetCandidateFilter(null)">All (@CandidateCount(null))</button>
            <button type="button" class="btn @CandidateFilterClass(VulnerabilitySourceHelper.Network)" @onclick="() => SetCandidateFilter(VulnerabilitySourceHelper.Network)">Network (@CandidateCount(VulnerabilitySourceHelper.Network))</button>
            <button type="button" class="btn @CandidateFilterClass(VulnerabilitySourceHelper.Registry)" @onclick="() => SetCandidateFilter(VulnerabilitySourceHelper.Registry)">Registry (@CandidateCount(VulnerabilitySourceHelper.Registry))</button>
            <button type="button" class="btn @CandidateFilterClass(VulnerabilitySourceHelper.Application)" @onclick="() => SetCandidateFilter(VulnerabilitySourceHelper.Application)">Below Top @_session.ExportTopN (@CandidateCount(VulnerabilitySourceHelper.Application))</button>
        </div>

        @if (_candidateFindings.Count == 0)
        {
            <div class="alert alert-success mb-0">All visible candidates are already in the export set.</div>
        }
        else
        {
            <div class="table-responsive">
                <table class="table table-sm table-hover align-middle">
                    <thead class="table-light">
                        <tr>
                            <th>Source</th>
                            <th>Product</th>
                            <th class="sortable-th" role="button" @onclick='() => SetCandidateSort("severity")'>Severity @CandidateSortIcon("severity")</th>
                            <th class="text-end sortable-th" role="button" @onclick='() => SetCandidateSort("risk")'>Risk @CandidateSortIcon("risk")</th>
                            <th class="text-end sortable-th" role="button" @onclick='() => SetCandidateSort("epss")'>EPSS @CandidateSortIcon("epss")</th>
                            <th class="text-end sortable-th" role="button" @onclick='() => SetCandidateSort("cvss")'>CVSS @CandidateSortIcon("cvss")</th>
                            <th class="text-end sortable-th" role="button" @onclick='() => SetCandidateSort("hosts")'>Hosts @CandidateSortIcon("hosts")</th>
                            <th></th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var candidate in _candidateFindings)
                        {
                            <tr>
                                <td><span class="badge bg-secondary">@candidate.Source</span></td>
                                <td class="text-break">
                                    @candidate.Product
                                    @if (CveOnlyFindingDisplay.IsCveOnlyFinding(candidate))
                                    {
                                        <span class="badge bg-info text-dark ms-1">CVE-only</span>
                                    }
                                </td>
                                <td>@ReviewCandidatePool.SeverityLabel(candidate)</td>
                                <td class="text-end">@candidate.RiskScore.ToString("N2")</td>
                                <td class="text-end">@candidate.Epss.ToString("N4")</td>
                                <td class="text-end">@candidate.AvgCvss.ToString("N2")</td>
                                <td class="text-end">@IncludedHostCount(candidate)</td>
                                <td class="text-end text-nowrap">
                                    <button type="button" class="btn btn-outline-primary btn-sm" @onclick="() => PromoteCandidate(candidate)">Add to export</button>
                                    <button type="button" class="btn btn-outline-secondary btn-sm" @onclick="() => PreviewCandidate(candidate)">Preview</button>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    }

    @if (_orderedFindings.Count > 0 && _activeTab == ReviewTab)
    {
    <div class="row">
        <div class="col-md-4">
            @if (_selectedFindingRanks.Count > 0)
            {
                <div class="alert alert-light py-2 small mb-2">
                    <strong>@_selectedFindingRanks.Count</strong> @(_selectedFindingRanks.Count == 1 ? "finding" : "findings") selected
                    <div class="btn-group btn-group-sm ms-2">
                        <button type="button" class="btn btn-outline-secondary" @onclick="() => BulkSetFindingExport(true)">Include in export</button>
                        <button type="button" class="btn btn-outline-secondary" @onclick="() => BulkSetFindingExport(false)">Exclude from export</button>
                    </div>
                </div>
            }
            <div class="list-group" style="max-height: 70vh; overflow-y: auto;">
                <Virtualize Items="_orderedFindings" Context="f" ItemSize="88">
                    <button type="button"
                            class="list-group-item list-group-item-action @(IsFindingSelected(f) ? "active" : "") @FindingListClass(f)"
                            @onclick="e => OnFindingClick(f, e)">
                        <div class="d-flex justify-content-between align-items-start gap-2">
                            <div class="flex-grow-1 text-break">
                                @if (ReviewSessionRanker.GetExportRank(_session!, f) is int exportRank)
                                {
                                    <strong>@exportRank.</strong>@(" ")@f.Product
                                    @if (CveOnlyFindingDisplay.IsCveOnlyFinding(f))
                                    {
                                        <span class="badge bg-info text-dark ms-1">CVE-only</span>
                                    }
                                    @if (f.ManuallyPromoted)
                                    {
                                        <span class="badge bg-primary ms-1">Added</span>
                                    }
                                }
                                else if (f.ConnectSecureSuppressed)
                                {
                                    <span class="text-muted"><s>#@f.OriginalRank @f.Product</s></span>
                                    <span class="badge bg-warning text-dark ms-1">Suppressed</span>
                                }
                                else if (IsReserveFinding(f))
                                {
                                    <span class="text-muted">#@f.OriginalRank @f.Product</span>
                                    @if (VulnerabilitySourceHelper.IsManualCandidateSource(f.Source))
                                    {
                                        <span class="badge bg-info text-dark ms-1">@f.Source</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-light text-dark ms-1">Below Top N</span>
                                    }
                                }
                                else if (f.ExcludedFromExport)
                                {
                                    <span class="text-muted"><s>#@f.OriginalRank @f.Product</s></span>
                                    <span class="badge bg-secondary ms-1">Excluded</span>
                                }
                            </div>
                            <span class="badge bg-dark flex-shrink-0">@f.RiskScore.ToString("N2")</span>
                        </div>
                        <small class="d-block mt-1">@FormatFindingRiskSummary(f)</small>
                        @if (CveOnlyFindingDisplay.IsCveOnlyFinding(f))
                        {
                            <small class="d-block text-info-emphasis">@CveOnlyFindingDisplay.GetListSubtitle(f)</small>
                        }
                        <small class="d-block">@f.Status · @IncludedHostCount(f) host(s)@FormatFindingBadges(f)</small>
                    </button>
                </Virtualize>
            </div>
            <div class="form-text mt-2">Shift-click findings to select a range.</div>
        </div>
        <div class="col-md-8">
            @if (_selected is not null)
            {
                <div class="card">
                    <div class="card-header">
                        <div>
                            <strong>@FormatFindingTitle(_selected)</strong> (@_selected.Source)
                            @if (_selected.ConnectSecureSuppressed)
                            {
                                <span class="badge bg-warning text-dark mt-2">Suppressed in ConnectSecure</span>
                                @if (!string.IsNullOrWhiteSpace(_selected.SuppressionReason))
                                {
                                    <div class="form-text">@_selected.SuppressionReason@if (!string.IsNullOrWhiteSpace(_selected.SuppressionComments)) { <text> — @_selected.SuppressionComments</text> }</div>
                                }
                            }
                            else
                            {
                                <div class="form-check mt-2 mb-0">
                                    <input class="form-check-input" type="checkbox" checked="@_selected.IncludeInExport"
                                           @onchange="e => SetFindingExport(e.Value is true)" id="includeExport" />
                                    <label class="form-check-label" for="includeExport">Include finding in export</label>
                                </div>
                                <div class="form-text">Uncheck to remove this item from the client report. The next ranked application finding takes its place (@ExportSetLabel()). Add network and registry items from the Add to export tab.</div>
                            }
                        </div>
                    </div>
                    <div class="card-body">
                        <p>@FormatFindingRiskSummary(_selected)</p>
                        @if (ShouldShowCveSection(_selected))
                        {
                            var cveIds = GetSelectedCveIds();
                            var cveCount = cveIds.Count;
                            var isCveOnly = CveOnlyFindingDisplay.IsCveOnlyFinding(_selected);
                            var cveContext = CveOnlyFindingDisplay.ParseNvdEnrichment(_selected.NvdEnrichment);
                            <details class="mb-3 border rounded p-3 bg-light">
                                <summary class="review-collapsible-summary">
                                    @(isCveOnly ? "What this CVE is about" : "CVEs")@if (cveCount > 0) { <span class="text-muted"> (@cveCount.ToString("N0"))</span> }
                                </summary>
                                <div class="mt-2">
                                @if (isCveOnly)
                                {
                                    <div class="alert alert-info py-2 small mb-3">@CveOnlyFindingDisplay.Explanation</div>
                                }
                                <div class="d-flex flex-wrap justify-content-end mb-2">
                                        <button type="button" class="btn btn-outline-primary btn-sm" disabled="@_nvdBusy" @onclick="FetchNvdForSelected">
                                            @(_nvdBusy ? "Fetching NVD…" : string.IsNullOrWhiteSpace(_selected.NvdEnrichment) ? "Load NVD details" : "Refresh NVD details")
                                        </button>
                                </div>
                                @if (cveCount > 0)
                                {
                                    <div class="d-flex flex-wrap gap-2 mb-2">
                                        @foreach (var cve in cveIds)
                                        {
                                            <a class="btn btn-sm btn-outline-secondary" href="@CveReferenceHelper.GetNvdDetailUrl(cve)" target="_blank" rel="noopener">@cve</a>
                                        }
                                    </div>
                                }
                                @if (!string.IsNullOrWhiteSpace(cveContext.Description))
                                {
                                    <p class="small mb-2">@cveContext.Description</p>
                                }
                                else if (_nvdBusy && string.IsNullOrWhiteSpace(_selected.NvdEnrichment))
                                {
                                    <p class="small text-muted mb-2">Loading NVD description…</p>
                                }
                                else if (string.IsNullOrWhiteSpace(_selected.NvdEnrichment))
                                {
                                    <p class="small text-muted mb-2">No NVD summary yet. Use Load NVD details or open a CVE link above.</p>
                                }
                                @if (cveContext.ReferenceUrls.Count > 0)
                                {
                                    <div class="small">
                                        <strong>Advisories:</strong>
                                        <ul class="mb-0 ps-3">
                                            @foreach (var url in cveContext.ReferenceUrls)
                                            {
                                                <li><a href="@url" target="_blank" rel="noopener">@url</a></li>
                                            }
                                        </ul>
                                    </div>
                                }
                                @if (!string.IsNullOrWhiteSpace(_nvdStatus))
                                {
                                    <div class="form-text mt-2">@_nvdStatus</div>
                                }
                                </div>
                            </details>
                        }

                        <div class="mb-3 border rounded p-3 bg-light">
                            <label class="form-label mb-2">Time estimate &amp; billing</label>
                                <div class="row g-2 align-items-end">
                                    <div class="col-sm-4">
                                        <label class="form-label small mb-1" for="timeEstimateHours">Hours</label>
                                        <input id="timeEstimateHours" class="form-control form-control-sm" type="number" min="0" step="0.25"
                                               @bind="_selected.TimeEstimateHours" @bind:after="OnTimeEstimateFieldChanged" list="timeEstimatePresetsDetail" />
                                        <datalist id="timeEstimatePresetsDetail">
                                            @foreach (var preset in TimeEstimatePresets)
                                            {
                                                <option value="@preset"></option>
                                            }
                                        </datalist>
                                    </div>
                                    <div class="col-sm-8">
                                        <div class="form-check">
                                            <input class="form-check-input" type="checkbox" @bind="_selected.AfterHours" @bind:after="OnTimeEstimateFieldChanged" id="afterHoursDetail" />
                                            <label class="form-check-label" for="afterHoursDetail">After-hours work</label>
                                        </div>
                                        @if (_session.IsRmitPlus)
                                        {
                                            <div class="form-check">
                                                <input class="form-check-input" type="checkbox" @bind="_selected.ThirdParty" @bind:after="OnTimeEstimateFieldChanged" id="thirdPartyDetail" />
                                                <label class="form-check-label" for="thirdPartyDetail">3rd party application (not covered by RMIT+ flat rate)</label>
                                            </div>
                                            <div class="form-check">
                                                <input class="form-check-input" type="checkbox" @bind="_selected.TicketGenerated" @bind:after="OnTimeEstimateFieldChanged" id="ticketGeneratedDetail" />
                                                <label class="form-check-label" for="ticketGeneratedDetail">Ticket already generated</label>
                                            </div>
                                        }
                                    </div>
                                </div>
                                <div class="form-text mt-2">
                                    Same fields as the <button type="button" class="btn btn-link btn-sm p-0 align-baseline" @onclick="() => SetActiveTab(TimeEstimatesTab)">Time estimates</button> tab.
                                    Applies to grouped products (Visual C++, .NET, etc.).
                                </div>
                            </div>
                            @if (ConnectSecure.IsConfigured)
                            {
                                <div class="mb-3 border rounded p-3">
                                    <label class="form-label mb-2">ConnectSecure suppression <HelpTip Text="Company-wide suppress in ConnectSecure. Click Load suppress options, pick CVE problem or remediation item, then Suppress. Requires session company id." AlignEnd="true" /></label>
                                    @if (!TryGetCompanyId(out _))
                                    {
                                        <p class="small text-warning mb-2">Set the ConnectSecure company id for this session to suppress from review.</p>
                                        <div class="row g-2 align-items-end mb-2">
                                            <div class="col-sm-4">
                                                <label class="form-label small mb-1" for="sessionCompanyId">Company id</label>
                                                <input id="sessionCompanyId" class="form-control form-control-sm" @bind="_sessionCompanyId" placeholder="e.g. 12345" />
                                            </div>
                                            <div class="col-sm-8">
                                                <button type="button" class="btn btn-sm btn-outline-primary" @onclick="SaveSessionCompanyId">Save company id</button>
                                            </div>
                                        </div>
                                    }
                                    else if (_selected.ConnectSecureSuppressed)
                                    {
                                        <p class="small text-muted mb-2">
                                            This finding was suppressed company-wide during review
                                            @if (_selected.SuppressedAt.HasValue)
                                            {
                                                <text> on @_selected.SuppressedAt.Value.LocalDateTime.ToString("g")</text>
                                            }.
                                            It will not appear on future remediation lists.
                                        </p>
                                        @if (!string.IsNullOrWhiteSpace(_unsuppressError))
                                        {
                                            <div class="alert alert-danger py-1 small mb-2">@_unsuppressError</div>
                                        }
                                        <div class="d-flex gap-2 flex-wrap">
                                            @if (_confirmUnsuppress)
                                            {
                                                <button type="button" class="btn btn-sm btn-danger" disabled="@_unsuppressBusy" @onclick="ConfirmUnsuppressFindingAsync">
                                                    @(_unsuppressBusy ? "Removing…" : "Confirm unsuppress")
                                                </button>
                                                <button type="button" class="btn btn-sm btn-outline-secondary" disabled="@_unsuppressBusy" @onclick="() => _confirmUnsuppress = false">Cancel</button>
                                            }
                                            else
                                            {
                                                <button type="button" class="btn btn-sm btn-outline-warning" disabled="@(_unsuppressBusy || !TryGetCompanyId(out _))" @onclick="() => _confirmUnsuppress = true">
                                                    Unsuppress in ConnectSecure
                                                </button>
                                            }
                                        </div>
                                        <p class="form-text small mb-0">Removes the company-wide suppression in ConnectSecure and clears the suppressed state on this finding.</p>
                                    }
                                    else
                                    {
                                        <p class="small text-muted mb-2">
                                            Suppress company-wide in ConnectSecure. Application items use the remediation plan;
                                            CVE/registry/network items use problem ids.
                                        </p>
                                        @if (!_suppressOptionsLoaded)
                                        {
                                            @if (_suppressMatchLoading)
                                            {
                                                <p class="text-muted small mb-2">Loading suppress options…</p>
                                            }
                                            else
                                            {
                                                <button type="button" class="btn btn-sm btn-outline-primary" disabled="@(!TryGetCompanyId(out _))" @onclick="LoadSuppressOptionsAsync">
                                                    Load suppress options
                                                </button>
                                                @if (!TryGetCompanyId(out _))
                                                {
                                                    <p class="form-text small mb-0">Set the session company id above before loading.</p>
                                                }
                                            }
                                        }
                                        else
                                        {
                                        @if (!string.IsNullOrWhiteSpace(_suppressStatus))
                                        {
                                            <p class="text-muted small mb-2">@_suppressStatus</p>
                                        }
                                        @if (!string.IsNullOrWhiteSpace(_suppressError))
                                        {
                                            <div class="alert alert-danger py-1 small mb-2">@_suppressError</div>
                                        }
                                        @if (_suppressMatchLoading)
                                        {
                                            <p class="text-muted small mb-2">Loading suppress options…</p>
                                        }
                                        else if (!_suppressUsesProblemId)
                                        {
                                            @if (_suppressRemediations.Count == 0)
                                            {
                                                <p class="text-muted small mb-2">No remediation items for this company. Verify the company id on this session.</p>
                                            }
                                            else
                                            {
                                                <label class="form-label small mb-1" for="suppressSolutionSelect">Remediation item</label>
                                                <select id="suppressSolutionSelect" class="form-select form-select-sm mb-2" value="@_selectedSolutionId" @onchange="OnSuppressSolutionChanged">
                                                    <option value="0">-- Select remediation item --</option>
                                                    @foreach (var entry in _suppressRemediations)
                                                    {
                                                        <option value="@entry.SolutionId">@entry.Product (solution @entry.SolutionId, @entry.AffectedAssets host(s))</option>
                                                    }
                                                </select>
                                            }
                                            @if (GetEffectiveSolutionId() <= 0)
                                            {
                                                <p class="text-muted small mb-2">Select a remediation item above to enable suppress.</p>
                                            }
                                            else if (CanSuppressSelected())
                                            {
                                                <p class="text-success small mb-2">Ready to suppress (@GetSuppressTargetSummary()).</p>
                                            }
                                        }
                                        else
                                        {
                                            @if (_suppressProblems.Count == 0 && GetEffectiveProblemId() <= 0)
                                            {
                                                <p class="text-muted small mb-2">No CVE problem match found. Try <a href="/vulnerability-suppress">Suppress Vulnerabilities</a> or Deep search.</p>
                                            }
                                            else
                                            {
                                                <label class="form-label small mb-1" for="suppressProblemSelect">CVE problem</label>
                                                <select id="suppressProblemSelect" class="form-select form-select-sm mb-2" value="@_selectedProblemId" @onchange="OnSuppressProblemChanged">
                                                    <option value="0">-- Select CVE problem --</option>
                                                    @foreach (var entry in _suppressProblems)
                                                    {
                                                        <option value="@entry.ProblemId">@entry.ProblemName (problem @entry.ProblemId)</option>
                                                    }
                                                </select>
                                            }
                                            @if (GetEffectiveProblemId() <= 0)
                                            {
                                                <p class="text-muted small mb-2">Select a CVE problem above to enable suppress.</p>
                                            }
                                            else if (CanSuppressSelected())
                                            {
                                                <p class="text-success small mb-2">Ready to suppress (@GetSuppressTargetSummary()).</p>
                                            }
                                        }
                                        <div class="row g-2">
                                            <div class="col-md-4">
                                                <label class="form-label small mb-1" for="suppressReason">Reason</label>
                                                <select id="suppressReason" class="form-select form-select-sm" @bind="_suppressReason">
                                                    <option value="False positive">False positive</option>
                                                    <option value="Accepted risk">Accepted risk</option>
                                                    <option value="Business requirement">Business requirement</option>
                                                    <option value="Compensating control">Compensating control</option>
                                                    <option value="Other">Other</option>
                                                </select>
                                            </div>
                                            <div class="col-md-8">
                                                <label class="form-label small mb-1" for="suppressComments">Comments</label>
                                                <input id="suppressComments" class="form-control form-control-sm" @bind="_suppressComments" placeholder="Optional notes for the suppression record" />
                                            </div>
                                        </div>
                                        <div class="mt-2 d-flex gap-2 flex-wrap">
                                            <button type="button" class="btn btn-sm btn-warning" disabled="@(_suppressBusy || _suppressMatchLoading || !CanSuppressSelected())" @onclick="ConfirmSuppressFindingAsync">
                                                @(_suppressBusy ? "Suppressing…" : "Suppress in ConnectSecure")
                                            </button>
                                            <button type="button" class="btn btn-sm btn-outline-secondary" disabled="@_suppressMatchLoading" @onclick="RetrySuppressLookupAsync">Deep search</button>
                                            <button type="button" class="btn btn-sm btn-outline-secondary" disabled="@_suppressMatchLoading" @onclick="LoadSuppressOptionsAsync">Reload options</button>
                                        </div>
                                        }
                                    }
                                </div>
                            }
                            <div class="mb-3">
                                <div class="d-flex justify-content-between align-items-center mb-2">
                                    <label class="form-label mb-0">Affected systems</label>
                                    <div class="btn-group btn-group-sm">
                                        <button type="button" class="btn btn-outline-secondary" @onclick="SelectAllHosts">Select all</button>
                                        <button type="button" class="btn btn-outline-secondary" @onclick="DeselectAllHosts">Deselect all</button>
                                        <button type="button" class="btn btn-outline-secondary" disabled="@_usernameRefreshBusy" @onclick="RefreshUsernamesAsync">Refresh usernames</button>
                                    </div>
                                </div>
                                @if ((_selected.AffectedSystems ?? []).Count == 0)
                                {
                                    <p class="text-muted small mb-0">No per-host breakdown for this finding.</p>
                                }
                                else
                                {
                                    <div class="table-responsive border rounded" style="max-height: 260px; overflow-y: auto;">
                                        <table class="table table-sm table-hover mb-0">
                                            <thead class="table-light sticky-top">
                                                <tr>
                                                    <th style="width: 2.5rem;">Include</th>
                                                    <th>Host</th>
                                                    <th>IP</th>
                                                    <th>User</th>
                                                    <th class="text-end">Vulns</th>
                                                </tr>
                                            </thead>
                                            <tbody>
                                                @foreach (var s in (_selected.AffectedSystems ?? []).OrderByDescending(x => x.VulnCount))
                                                {
                                                    <tr class="@(IsHostIncluded(s) ? "" : "table-secondary text-muted")">
                                                        <td>
                                                            <input class="form-check-input" type="checkbox" checked="@IsHostIncluded(s)"
                                                                   @onclick="e => OnHostCheckboxClick(s, e)" @onclick:preventDefault />
                                                        </td>
                                                        <td>@(string.IsNullOrWhiteSpace(s.HostName) ? "—" : s.HostName)</td>
                                                        <td>@s.Ip</td>
                                                        <td>@(string.IsNullOrWhiteSpace(s.Username) ? "—" : s.Username)</td>
                                                        <td class="text-end">@s.VulnCount</td>
                                                    </tr>
                                                }
                                            </tbody>
                                        </table>
                                    </div>
                                    <div class="form-text">
                                        Uncheck hosts to omit from exports. Shift-click to toggle a range.
                                        @if (_selected is not null && OsHostVulnThresholdHelper.HasActiveThreshold(_userSettings, _selected.Product, _selected.Source))
                                        {
                                            <span> OS threshold: hosts below @GetOsThresholdLabel(_selected) vulns are excluded.</span>
                                        }
                                    </div>
                                }
                            </div>

                        <div class="mb-3">
                            <label class="form-label">Status</label>
                            <select class="form-select" @bind="_selected.Status" @bind:after="ScheduleSave">
                                @foreach (FindingStatus s in Enum.GetValues<FindingStatus>())
                                {
                                    <option value="@s">@s</option>
                                }
                            </select>
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Revised Remediation</label>
                            <textarea class="form-control" rows="6" @bind="_selected.RevisedRemediation" @bind:after="ScheduleSave"></textarea>
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Meeting Notes</label>
                            <textarea class="form-control" rows="3" @bind="_selected.MeetingNotes" @bind:after="ScheduleSave"></textarea>
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Tasks (one per line)</label>
                            <textarea class="form-control" rows="3" @bind="_tasksText" @bind:after="UpdateTasks"></textarea>
                        </div>

                        @if (!string.IsNullOrWhiteSpace(_selected.OriginalFix))
                        {
                            <details class="mt-3">
                                <summary>Patch notes from scan</summary>
                                <p class="small text-muted mb-1">Version and patch details from ConnectSecure. Ticket exports include this when it differs from your remediation text.</p>
                                <p class="small mb-0">@_selected.OriginalFix</p>
                            </details>
                        }
                    </div>
                </div>
            }
        </div>
    </div>
    }
}

@code {
    private const int MaxDisplayedCveLinks = 12;

    private const string ReviewTab = "review";
    private const string AddToExportTab = "add";
    private const string TimeEstimatesTab = "time";

    private static readonly decimal[] TimeEstimatePresets = [0.25m, 0.5m, 0.75m, 1m, 1.5m, 2m, 2.5m, 3m, 4m, 5m, 6m, 8m];

    [Parameter] public string SessionId { get; set; } = "";

    private ReviewSession? _session;
    private ReviewFinding? _selected;
    private UserSettings _userSettings = new();
    private string _activeTab = ReviewTab;
    private string? _saveStatus;
    private string _tasksText = "";
    private CancellationTokenSource? _saveCts;
    private HashSet<int> _selectedFindingRanks = [];
    private int? _findingAnchorRank;
    private readonly CheckboxRangeColumn _hostIncludeRange = new();
    private readonly CheckboxRangeColumn _afterHoursRange = new();
    private bool _nvdBusy;
    private string? _nvdStatus;
    private bool _usernameRefreshBusy;
    private string? _usernameRefreshError;
    private readonly CheckboxRangeColumn _thirdPartyRange = new();
    private readonly CheckboxRangeColumn _ticketGeneratedRange = new();
    private string? _candidateSourceFilter;
    private readonly TableColumnSort _candidateSort = new("risk", defaultDescending: true);
    private List<SuppressibleRemediationEntry> _suppressRemediations = [];
    private List<SuppressibleProblemEntry> _suppressProblems = [];
    private bool _suppressUsesProblemId;
    private int _selectedSolutionId;
    private int _selectedProblemId;
    private string _sessionCompanyId = "";
    private bool _suppressMatchLoading;
    private bool _suppressOptionsLoaded;
    private bool _suppressBusy;
    private bool _confirmUnsuppress;
    private bool _unsuppressBusy;
    private string? _unsuppressError;
    private string? _suppressError;
    private string? _suppressStatus;
    private string _suppressReason = "False positive";
    private string _suppressComments = "";
    private int _suppressLoadGeneration;
    private int? _cachedRemediationCompanyId;
    private List<SuppressibleRemediationEntry> _cachedRemediations = [];
    private readonly Dictionary<string, SuppressibleProblemEntry?> _problemLookupCache = new(StringComparer.OrdinalIgnoreCase);
    private CancellationTokenSource? _suppressLoadCts;
    private List<ReviewFinding> _orderedFindings = [];
    private List<ReviewFinding> _candidateFindings = [];
    private List<TimeEstimateGroupRow> _timeEstimateGroups = [];

    private enum TimeEstimateCheckbox { AfterHours, ThirdParty, TicketGenerated }

    protected override async Task OnParametersSetAsync()
    {
        _userSettings = SettingsSvc.LoadUserSettings();
        _session = await SessionRepo.GetAsync(SessionId);
        if (_session is not null)
        {
            _session.Findings ??= [];
            var beforeProducts = _session.Findings.Select(f => f.Product).ToList();
            var beforeFixes = _session.Findings.Select(f => f.OriginalFix).ToList();
            var hadCveData = _session.Findings.Any(f =>
                !string.IsNullOrWhiteSpace(f.CveIds) || CveReferenceHelper.IsCveOnlyProduct(f.Product));
            ReviewSessionRanker.EnsureLegacyFields(_session, Options);
            var namesChanged = _session.Findings.Zip(beforeProducts, (after, prior) =>
                !string.Equals(after.Product, prior, StringComparison.Ordinal)).Any(changed => changed);
            var fixesChanged = _session.Findings.Zip(beforeFixes, (after, prior) =>
                !string.Equals(after.OriginalFix, prior, StringComparison.Ordinal)).Any(changed => changed);
            if (namesChanged || fixesChanged || hadCveData)
                await SessionRepo.SaveAsync(_session);
            if (_session.Findings.Count > 0)
            {
                var first = _session.Findings.OrderBy(f => f.OriginalRank).First();
                _selectedFindingRanks = [first.OriginalRank];
                _findingAnchorRank = first.OriginalRank;
                SelectFinding(first);
            }

            _sessionCompanyId = _session.CompanyId ?? "";

            _ = AutoEnrichMissingAsync();
        }

        RefreshFindingCaches();
    }

    private void RefreshFindingCaches()
    {
        _orderedFindings = (_session?.Findings ?? []).OrderBy(x => x.OriginalRank).ToList();
        _candidateFindings = _session is null
            ? []
            : SortCandidates(ReviewCandidatePool.GetCandidates(_session, _candidateSourceFilter));
        _timeEstimateGroups = _session is null
            ? []
            : ReviewFindingTimeEstimate.GetExportGroups(_session).ToList();
    }

    private IReadOnlyList<ReviewFinding> GetOrderedFindings() => _orderedFindings;

    private void SetCandidateSort(string column)
    {
        _candidateSort.Toggle(column, defaultDescending: true);
        _candidateFindings = SortCandidates(_candidateFindings);
    }

    private string CandidateSortIcon(string column) => _candidateSort.Icon(column);

    private List<ReviewFinding> SortCandidates(IEnumerable<ReviewFinding> items)
    {
        IEnumerable<ReviewFinding> q = _candidateSort.Column switch
        {
            "severity" => _candidateSort.Descending
                ? items.OrderByDescending(ReviewCandidatePool.SeverityRank).ThenBy(f => f.OriginalRank)
                : items.OrderBy(ReviewCandidatePool.SeverityRank).ThenBy(f => f.OriginalRank),
            "risk" => _candidateSort.Descending
                ? items.OrderByDescending(f => f.RiskScore).ThenBy(f => f.OriginalRank)
                : items.OrderBy(f => f.RiskScore).ThenBy(f => f.OriginalRank),
            "epss" => _candidateSort.Descending
                ? items.OrderByDescending(f => f.Epss).ThenBy(f => f.OriginalRank)
                : items.OrderBy(f => f.Epss).ThenBy(f => f.OriginalRank),
            "cvss" => _candidateSort.Descending
                ? items.OrderByDescending(f => f.AvgCvss).ThenBy(f => f.OriginalRank)
                : items.OrderBy(f => f.AvgCvss).ThenBy(f => f.OriginalRank),
            "hosts" => _candidateSort.Descending
                ? items.OrderByDescending(GetIncludedHostCountValue).ThenBy(f => f.OriginalRank)
                : items.OrderBy(GetIncludedHostCountValue).ThenBy(f => f.OriginalRank),
            _ => items.OrderByDescending(f => f.RiskScore).ThenBy(f => f.OriginalRank)
        };

        return q.ToList();
    }

    private static int GetIncludedHostCountValue(ReviewFinding finding) =>
        (finding.AffectedSystems ?? []).Count(s => !s.ExcludedFromExport);

    private bool IsFindingSelected(ReviewFinding finding) =>
        _selectedFindingRanks.Contains(finding.OriginalRank);

    private void OnFindingClick(ReviewFinding finding, MouseEventArgs e)
    {
        if (_session is null) return;

        var ordered = GetOrderedFindings();
        var ranks = ordered.Select(f => f.OriginalRank).ToList();
        var index = ranks.IndexOf(finding.OriginalRank);
        if (index < 0) return;

        if (e.ShiftKey && _findingAnchorRank is int anchorRank)
        {
            var anchorIndex = ranks.IndexOf(anchorRank);
            if (anchorIndex >= 0)
            {
                var start = Math.Min(anchorIndex, index);
                var end = Math.Max(anchorIndex, index);
                _selectedFindingRanks.Clear();
                for (var i = start; i <= end; i++)
                    _selectedFindingRanks.Add(ranks[i]);
            }
        }
        else
        {
            _selectedFindingRanks.Clear();
            _selectedFindingRanks.Add(finding.OriginalRank);
            _findingAnchorRank = finding.OriginalRank;
        }

        _hostIncludeRange.Reset();
        SelectFinding(finding);
    }

    private void BulkSetFindingExport(bool include)
    {
        if (_session is null || _selectedFindingRanks.Count == 0) return;

        foreach (var finding in _session.Findings.Where(f => _selectedFindingRanks.Contains(f.OriginalRank)))
        {
            if (finding.ConnectSecureSuppressed)
                continue;

            if (include && (VulnerabilitySourceHelper.IsManualCandidateSource(finding.Source) ||
                            ReviewCandidatePool.IsApplicationReserve(finding)))
                ReviewSessionRanker.PromoteToExport(_session, finding);
            else
                ReviewSessionRanker.SetExportIncluded(_session, finding, include);
        }

        ScheduleSave();
    }

    private string ExportSetLabel()
    {
        if (_session is null) return "";
        var exportCount = ReviewSessionRanker.GetExportFindings(_session).Count;
        var manual = _session.Findings.Count(f => f.IncludeInExport && f.ManuallyPromoted);
        if (_session.ExportTopN <= 0)
            return $"All ({exportCount})";

        return manual > 0
            ? $"{exportCount} in export (Top {_session.ExportTopN} suggested + {manual} added)"
            : $"{exportCount} in export (Top {_session.ExportTopN})";
    }

    private string FormatFindingTitle(ReviewFinding finding)
    {
        if (_session is null) return finding.Product;
        var exportRank = ReviewSessionRanker.GetExportRank(_session, finding);
        return exportRank.HasValue
            ? $"{exportRank}. {finding.Product}"
            : $"#{finding.OriginalRank} {finding.Product}";
    }

    private bool IsReserveFinding(ReviewFinding finding) =>
        _session is not null &&
        !finding.IncludeInExport &&
        !finding.ExcludedFromExport &&
        !finding.ConnectSecureSuppressed;

    private void SetFindingExport(bool include)
    {
        if (_selected is null || _session is null) return;

        if (include &&
            (VulnerabilitySourceHelper.IsManualCandidateSource(_selected.Source) ||
             ReviewCandidatePool.IsApplicationReserve(_selected)))
            ReviewSessionRanker.PromoteToExport(_session, _selected);
        else
            ReviewSessionRanker.SetExportIncluded(_session, _selected, include);

        ScheduleSave();
    }

    private int CandidateCount(string? sourceFilter = null) =>
        _session is null ? 0 : ReviewCandidatePool.CountCandidates(_session, sourceFilter);

    private IReadOnlyList<ReviewFinding> GetCandidateFindings() => _candidateFindings;

    private void SetCandidateFilter(string? source)
    {
        _candidateSourceFilter = source;
        RefreshFindingCaches();
    }

    private string CandidateFilterClass(string? source) =>
        string.Equals(_candidateSourceFilter, source, StringComparison.OrdinalIgnoreCase) ||
        (_candidateSourceFilter is null && source is null)
            ? "btn-primary"
            : "btn-outline-primary";

    private async Task PromoteCandidate(ReviewFinding finding)
    {
        if (_session is null) return;
        ReviewSessionRanker.PromoteToExport(_session, finding);
        _selectedFindingRanks = [finding.OriginalRank];
        _findingAnchorRank = finding.OriginalRank;
        SelectFinding(finding);
        SetActiveTab(ReviewTab);
        ScheduleSave();

        if (CveEnrichmentPolicy.ShouldEnrich(finding))
            await EnrichFindingInBackgroundAsync(finding);
    }

    private async Task EnrichFindingInBackgroundAsync(ReviewFinding finding)
    {
        if (_session is null || _nvdBusy)
            return;

        _nvdBusy = true;
        try
        {
            if (await CveEnrichment.EnrichFindingAsync(finding, _userSettings, applyToRemediation: true))
            {
                await SessionRepo.SaveAsync(_session);
                _saveStatus = $"NVD details added for {finding.Product} at {DateTime.Now:HH:mm:ss}";
                await InvokeAsync(StateHasChanged);
            }
        }
        catch (Exception ex)
        {
            _nvdStatus = ex.Message;
            await InvokeAsync(StateHasChanged);
        }
        finally
        {
            _nvdBusy = false;
        }
    }

    private void PreviewCandidate(ReviewFinding finding)
    {
        _selectedFindingRanks = [finding.OriginalRank];
        _findingAnchorRank = finding.OriginalRank;
        SelectFinding(finding);
        SetActiveTab(ReviewTab);
    }

    private void SelectFinding(ReviewFinding f)
    {
        _selected = f;
        f.Tasks ??= [];
        f.AffectedSystems ??= [];
        _tasksText = string.Join(Environment.NewLine, f.Tasks.Select(t => t.Text));
        _hostIncludeRange.Reset();
        _confirmUnsuppress = false;
        _unsuppressError = null;
        _suppressError = null;
        _suppressStatus = null;
        _suppressOptionsLoaded = false;
        _selectedSolutionId = 0;
        _selectedProblemId = 0;
        _suppressRemediations = [];
        _suppressProblems = [];
        _suppressLoadCts?.Cancel();

        if (CveEnrichmentPolicy.ShouldEnrich(f))
            _ = EnrichFindingInBackgroundAsync(f);
    }

    private Task LoadSuppressOptionsAsync()
    {
        if (_selected is null || _selected.ConnectSecureSuppressed)
            return Task.CompletedTask;

        ClearProblemLookupCacheForFinding(_selected);
        return LoadSuppressOptionsAsync(_selected, exhaustive: false);
    }

    private bool TryGetCompanyId(out int companyId)
    {
        companyId = 0;
        if (_session is null || string.IsNullOrWhiteSpace(_session.CompanyId))
            return false;

        return int.TryParse(_session.CompanyId.Trim(), out companyId) && companyId > 0;
    }

    private void OnSuppressProblemChanged(ChangeEventArgs e)
    {
        _selectedProblemId = int.TryParse(e.Value?.ToString(), out var id) ? id : 0;
    }

    private void OnSuppressSolutionChanged(ChangeEventArgs e)
    {
        _selectedSolutionId = int.TryParse(e.Value?.ToString(), out var id) ? id : 0;
    }

    private string GetSuppressTargetSummary()
    {
        if (_suppressUsesProblemId)
        {
            var problemId = GetEffectiveProblemId();
            var problem = _suppressProblems.FirstOrDefault(p => p.ProblemId == problemId);
            return problem is not null
                ? $"problem {problemId}, {problem.ProblemName}"
                : $"problem {problemId}";
        }

        var solutionId = GetEffectiveSolutionId();
        var solution = _suppressRemediations.FirstOrDefault(r => r.SolutionId == solutionId);
        return solution is not null
            ? $"solution {solutionId}, {solution.Product}"
            : $"solution {solutionId}";
    }

    private async Task LoadSuppressOptionsAsync(ReviewFinding finding, bool exhaustive)
    {
        if (!TryGetCompanyId(out var companyId))
            return;

        _suppressLoadCts?.Cancel();
        _suppressLoadCts?.Dispose();
        _suppressLoadCts = new CancellationTokenSource(exhaustive ? TimeSpan.FromMinutes(3) : TimeSpan.FromSeconds(75));
        var loadCt = _suppressLoadCts.Token;

        var generation = ++_suppressLoadGeneration;
        _suppressMatchLoading = true;
        _suppressError = null;
        _suppressStatus = null;
        _selectedSolutionId = 0;
        _selectedProblemId = 0;
        _suppressUsesProblemId = !ReviewSuppressPathHelper.UsesApplicationSolutionPath(
            finding.Source, finding.Product, finding.CveIds);
        var shouldSaveSession = false;
        await InvokeAsync(StateHasChanged);

        try
        {
            if (!_suppressUsesProblemId)
            {
                if (_cachedRemediationCompanyId != companyId)
                {
                    _cachedRemediations = (await PatchService.GetSuppressibleRemediationsAsync(companyId, loadCt)).ToList();
                    _cachedRemediationCompanyId = companyId;
                }

                _suppressRemediations = _cachedRemediations;

                if (generation != _suppressLoadGeneration)
                    return;

                var match = SuppressibleRemediationMatcher.Match(_suppressRemediations, finding.Product);
                if (match.HasMatch)
                    _selectedSolutionId = match.Entry!.SolutionId;
                else if (match.AmbiguousMatches.Count == 1)
                    _selectedSolutionId = match.AmbiguousMatches[0].SolutionId;

                _suppressStatus = match.HasMatch
                    ? $"Auto-selected: {match.Entry!.Product} (solution {_selectedSolutionId})."
                    : _suppressRemediations.Count == 0
                        ? "No remediation items returned — verify company id."
                        : $"Select a remediation item ({_suppressRemediations.Count} available).";

                EnsureSolutionSelection(finding);
            }
            else
            {
                var cveIds = CveReferenceHelper.IsCveOnlyProduct(finding.Product)
                    ? CveReferenceHelper.SplitCveIds(finding.Product)
                    : CveReferenceHelper.SplitCveIds(finding.CveIds);

                if (finding.ConnectSecureProblemId is > 0)
                {
                    _selectedProblemId = finding.ConnectSecureProblemId.Value;
                    _suppressProblems =
                    [
                        new SuppressibleProblemEntry(
                            finding.ConnectSecureProblemId.Value,
                            cveIds.FirstOrDefault() ?? finding.Product,
                            finding.AffectedSystems?.Count ?? 0)
                    ];
                    _suppressStatus = $"Using saved problem id {_selectedProblemId}.";
                }
                else
                {
                    var hostIdentifiers = GetSuppressHostIdentifiers(finding);
                    foreach (var cve in cveIds)
                    {
                        var cacheKey = $"{companyId}|{cve}";
                        if (!_problemLookupCache.TryGetValue(cacheKey, out var lookedUp))
                        {
                            try
                            {
                                lookedUp = exhaustive
                                    ? await PatchService.LookupProblemByNameExhaustiveAsync(companyId, cve, hostIdentifiers, loadCt)
                                    : await PatchService.LookupProblemByNameAsync(companyId, cve, finding.Source, hostIdentifiers, loadCt);
                            }
                            catch (OperationCanceledException) when (loadCt.IsCancellationRequested)
                            {
                                if (generation == _suppressLoadGeneration)
                                    _suppressError = "ConnectSecure lookup timed out. Try Deep search (uses affected hosts) or verify API connectivity.";
                                return;
                            }

                            if (lookedUp is not null)
                                _problemLookupCache[cacheKey] = lookedUp;
                        }

                        if (generation != _suppressLoadGeneration)
                            return;

                        if (lookedUp is null)
                            continue;

                        _selectedProblemId = lookedUp.ProblemId;
                        finding.ConnectSecureProblemId = lookedUp.ProblemId;
                        shouldSaveSession = true;
                        _suppressProblems = [lookedUp];
                        _suppressStatus = $"Auto-selected: {lookedUp.ProblemName} (problem {_selectedProblemId}).";
                        break;
                    }

                    if (_selectedProblemId <= 0 && exhaustive)
                    {
                        foreach (var cve in cveIds)
                        {
                            var lookedUp = await PatchService.LookupProblemByNameExhaustiveAsync(
                                companyId, cve, hostIdentifiers, loadCt);
                            if (generation != _suppressLoadGeneration)
                                return;

                            if (lookedUp is null)
                                continue;

                            _selectedProblemId = lookedUp.ProblemId;
                            finding.ConnectSecureProblemId = lookedUp.ProblemId;
                            shouldSaveSession = true;
                            _suppressProblems = [lookedUp];
                            _suppressStatus = $"Auto-selected: {lookedUp.ProblemName} (problem {_selectedProblemId}).";
                            break;
                        }
                    }

                    if (_selectedProblemId <= 0)
                    {
                        _suppressStatus = exhaustive
                            ? $"No problem id found for {finding.Product} in ConnectSecure."
                            : $"No quick match for {finding.Product}. Click Deep search for a slower full lookup.";
                    }
                    else if (string.IsNullOrWhiteSpace(_suppressStatus))
                    {
                        _suppressStatus = $"Auto-selected problem id {_selectedProblemId}.";
                    }
                }

                EnsureProblemSelection(finding);
            }
        }
        catch (OperationCanceledException) when (loadCt.IsCancellationRequested)
        {
            if (generation == _suppressLoadGeneration)
                _suppressError = "ConnectSecure lookup timed out. Try Deep search (uses affected hosts) or verify API connectivity.";
        }
        catch (Exception ex)
        {
            if (generation == _suppressLoadGeneration)
                _suppressError = ex.Message;
        }
        finally
        {
            if (generation == _suppressLoadGeneration)
            {
                if (_suppressUsesProblemId)
                    EnsureProblemSelection(finding);
                else
                    EnsureSolutionSelection(finding);

                _suppressMatchLoading = false;
                _suppressOptionsLoaded = true;
                await InvokeAsync(StateHasChanged);
            }
        }

        if (shouldSaveSession && _session is not null)
            await SessionRepo.SaveAsync(_session);
    }

    private static IReadOnlyList<string> GetSuppressHostIdentifiers(ReviewFinding finding) =>
        (finding.AffectedSystems ?? [])
            .SelectMany(s => new[] { s.Ip, s.HostName })
            .Where(h => !string.IsNullOrWhiteSpace(h))
            .Distinct(StringComparer.OrdinalIgnoreCase)
            .ToList();

    private bool CanSuppressSelected()
    {
        if (_selected is null || _selected.ConnectSecureSuppressed || !_suppressOptionsLoaded || !TryGetCompanyId(out _))
            return false;

        return _suppressUsesProblemId
            ? GetEffectiveProblemId() > 0
            : GetEffectiveSolutionId() > 0;
    }

    private int GetEffectiveProblemId()
    {
        if (_selectedProblemId > 0)
            return _selectedProblemId;

        if (_selected?.ConnectSecureProblemId is int savedProblemId and > 0)
            return savedProblemId;

        return _suppressProblems.Count == 1 ? _suppressProblems[0].ProblemId : 0;
    }

    private int GetEffectiveSolutionId()
    {
        if (_selectedSolutionId > 0)
            return _selectedSolutionId;

        if (_selected?.ConnectSecureSolutionId is int savedSolutionId and > 0)
            return savedSolutionId;

        return _suppressRemediations.Count == 1 ? _suppressRemediations[0].SolutionId : 0;
    }

    private void EnsureProblemSelection(ReviewFinding finding)
    {
        if (finding.ConnectSecureProblemId is int savedProblemId and > 0)
            _selectedProblemId = savedProblemId;
        else if (_selectedProblemId <= 0 && _suppressProblems.Count == 1)
            _selectedProblemId = _suppressProblems[0].ProblemId;
    }

    private void EnsureSolutionSelection(ReviewFinding finding)
    {
        if (finding.ConnectSecureSolutionId is int savedSolutionId and > 0)
            _selectedSolutionId = savedSolutionId;
        else if (_selectedSolutionId <= 0 && _suppressRemediations.Count == 1)
            _selectedSolutionId = _suppressRemediations[0].SolutionId;
    }

    private void ClearProblemLookupCacheForFinding(ReviewFinding finding)
    {
        if (!TryGetCompanyId(out var companyId))
            return;

        var cveIds = CveReferenceHelper.IsCveOnlyProduct(finding.Product)
            ? CveReferenceHelper.SplitCveIds(finding.Product)
            : CveReferenceHelper.SplitCveIds(finding.CveIds);

        foreach (var cve in cveIds)
            _problemLookupCache.Remove($"{companyId}|{cve}");
    }

    private async Task RetrySuppressLookupAsync()
    {
        if (_selected is null || !TryGetCompanyId(out var companyId))
            return;

        _cachedRemediationCompanyId = null;
        _cachedRemediations = [];
        ClearProblemLookupCacheForFinding(_selected);
        ReviewSuppress.InvalidateCache(companyId);
        await LoadSuppressOptionsAsync(_selected, exhaustive: true);
    }

    private async Task SaveSessionCompanyId()
    {
        if (_session is null)
            return;

        _session.CompanyId = _sessionCompanyId.Trim();
        await SessionRepo.SaveAsync(_session);
        _saveStatus = "Company id saved.";
    }

    private async Task ConfirmSuppressFindingAsync()
    {
        if (_session is null || _selected is null || !TryGetCompanyId(out var companyId))
            return;

        ReviewSuppressEntry? entry = null;
        if (_suppressUsesProblemId)
        {
            var problemId = GetEffectiveProblemId();
            if (problemId <= 0)
                return;

            var problem = _suppressProblems.FirstOrDefault(p => p.ProblemId == problemId);
            var label = problem?.ProblemName
                ?? (CveReferenceHelper.IsCveOnlyProduct(_selected.Product) ? _selected.Product : _selected.CveIds);
            entry = new ReviewSuppressEntry(ReviewSuppressTargetKind.Problem, problemId, label, problem?.AffectedAssets ?? 0);
        }
        else
        {
            var solutionId = GetEffectiveSolutionId();
            if (solutionId <= 0)
                return;

            var solution = _suppressRemediations.FirstOrDefault(r => r.SolutionId == solutionId);
            entry = solution is not null
                ? ReviewSuppressEntry.FromSolution(solution)
                : new ReviewSuppressEntry(ReviewSuppressTargetKind.Solution, solutionId, _selected.Product, 0);
        }

        _suppressBusy = true;
        _suppressError = null;
        try
        {
            var result = await ReviewSuppress.SuppressCompanyWideAsync(
                companyId,
                entry,
                _selected.Product,
                _suppressReason,
                _suppressComments);

            if (entry.Kind == ReviewSuppressTargetKind.Problem)
                _selected.ConnectSecureProblemId = entry.Id;
            else
                _selected.ConnectSecureSolutionId = entry.Id;

            var recordId = await ReviewSuppress.ResolveSuppressRecordIdAsync(
                companyId,
                _selected.ConnectSecureSuppressRecordId,
                _selected.ConnectSecureProblemId,
                _selected.ConnectSecureSolutionId);
            if (recordId is > 0)
                _selected.ConnectSecureSuppressRecordId = recordId;

            ReviewSessionRanker.MarkConnectSecureSuppressed(_session, _selected, _suppressReason, _suppressComments);
            _suppressOptionsLoaded = false;
            _saveStatus = result.Message;
            await SessionRepo.SaveAsync(_session);
        }
        catch (Exception ex)
        {
            _suppressError = ex.Message;
        }
        finally
        {
            _suppressBusy = false;
            await InvokeAsync(StateHasChanged);
        }
    }

    private async Task ConfirmUnsuppressFindingAsync()
    {
        if (_session is null || _selected is null || !_selected.ConnectSecureSuppressed || !TryGetCompanyId(out var companyId))
            return;

        _unsuppressBusy = true;
        _unsuppressError = null;
        try
        {
            var recordId = await ReviewSuppress.ResolveSuppressRecordIdAsync(
                companyId,
                _selected.ConnectSecureSuppressRecordId,
                _selected.ConnectSecureProblemId,
                _selected.ConnectSecureSolutionId);
            if (recordId is not > 0)
            {
                _unsuppressError = "Could not find the ConnectSecure suppression record. It may already be removed.";
                return;
            }

            var result = await ReviewSuppress.UnsuppressCompanyWideAsync(recordId.Value);
            ReviewSessionRanker.MarkConnectSecureUnsuppressed(_session, _selected);
            _confirmUnsuppress = false;
            _suppressOptionsLoaded = false;
            _saveStatus = result.Message;
            await SessionRepo.SaveAsync(_session);
        }
        catch (Exception ex)
        {
            _unsuppressError = ex.Message;
        }
        finally
        {
            _unsuppressBusy = false;
            await InvokeAsync(StateHasChanged);
        }
    }

    private static string FormatAffectedSystems(ReviewFinding finding) =>
        FindingExportDetails.FormatAffectedSystemsInline(finding);

    private static string FindingListClass(ReviewFinding finding) =>
        finding.ConnectSecureSuppressed ? "opacity-50" :
        finding.IncludeInExport ? "" : "opacity-75";

    private static string IncludedHostCount(ReviewFinding finding)
    {
        var systems = finding.AffectedSystems ?? [];
        if (systems.Count == 0) return "0";
        var included = systems.Count(s => !s.ExcludedFromExport);
        return included == systems.Count ? included.ToString() : $"{included}/{systems.Count}";
    }

    private static bool IsHostIncluded(ReviewAffectedSystem system) => !system.ExcludedFromExport;

    private List<ReviewAffectedSystem> GetOrderedHosts() =>
        (_selected?.AffectedSystems ?? []).OrderByDescending(x => x.VulnCount).ToList();

    private static int FindHostIndex(ReviewAffectedSystem system, IReadOnlyList<ReviewAffectedSystem> hosts)
    {
        for (var i = 0; i < hosts.Count; i++)
        {
            if (HostKey(hosts[i]) == HostKey(system))
                return i;
        }

        return -1;
    }

    private static string HostKey(ReviewAffectedSystem system) =>
        $"{system.HostName}|{system.Ip}|{system.Username}";

    private void OnHostCheckboxClick(ReviewAffectedSystem system, MouseEventArgs e)
    {
        var hosts = GetOrderedHosts();
        var index = FindHostIndex(system, hosts);
        if (index < 0) return;

        _hostIncludeRange.Click(index, !IsHostIncluded(system), e, (i, on) => SetHostIncluded(hosts[i], on));
        ScheduleSave();
    }

    private static void SetHostIncluded(ReviewAffectedSystem system, bool included) =>
        system.ExcludedFromExport = !included;

    private void SelectAllHosts()
    {
        if (_selected?.AffectedSystems is null) return;
        foreach (var s in _selected.AffectedSystems)
            s.ExcludedFromExport = false;
        _hostIncludeRange.Reset();
        ScheduleSave();
    }

    private void DeselectAllHosts()
    {
        if (_selected?.AffectedSystems is null) return;
        foreach (var s in _selected.AffectedSystems)
            s.ExcludedFromExport = true;
        _hostIncludeRange.Reset();
        ScheduleSave();
    }

    private CheckboxRangeColumn TimeEstimateRangeFor(TimeEstimateCheckbox field) => field switch
    {
        TimeEstimateCheckbox.AfterHours => _afterHoursRange,
        TimeEstimateCheckbox.ThirdParty => _thirdPartyRange,
        TimeEstimateCheckbox.TicketGenerated => _ticketGeneratedRange,
        _ => _afterHoursRange
    };

    private static bool GetTimeEstimateCheckbox(TimeEstimateGroupRow row, TimeEstimateCheckbox field) => field switch
    {
        TimeEstimateCheckbox.AfterHours => row.SourceFinding.AfterHours,
        TimeEstimateCheckbox.ThirdParty => row.SourceFinding.ThirdParty,
        TimeEstimateCheckbox.TicketGenerated => row.SourceFinding.TicketGenerated,
        _ => false
    };

    private void SetTimeEstimateCheckbox(TimeEstimateGroupRow row, TimeEstimateCheckbox field, bool value)
    {
        switch (field)
        {
            case TimeEstimateCheckbox.AfterHours:
                row.SourceFinding.AfterHours = value;
                break;
            case TimeEstimateCheckbox.ThirdParty:
                row.SourceFinding.ThirdParty = value;
                break;
            case TimeEstimateCheckbox.TicketGenerated:
                row.SourceFinding.TicketGenerated = value;
                break;
        }
    }

    private void OnTimeEstimateCheckboxClick(int rowIndex, TimeEstimateCheckbox field, MouseEventArgs e)
    {
        var groups = GetTimeEstimateGroups();
        if (rowIndex < 0 || rowIndex >= groups.Count)
            return;

        var row = groups[rowIndex];
        var newValue = !GetTimeEstimateCheckbox(row, field);
        TimeEstimateRangeFor(field).Click(rowIndex, newValue, e, (i, on) =>
        {
            var target = groups[i];
            SetTimeEstimateCheckbox(target, field, on);
            OnTimeEstimateFieldChanged(target.SourceFinding);
        });
    }

    private void UpdateTasks()
    {
        if (_selected is null) return;
        _selected.Tasks = _tasksText
            .Split(['\r', '\n'], StringSplitOptions.RemoveEmptyEntries)
            .Select(line => new ReviewTask { Text = line.Trim() })
            .Where(t => !string.IsNullOrWhiteSpace(t.Text))
            .ToList();
        ScheduleSave();
    }

