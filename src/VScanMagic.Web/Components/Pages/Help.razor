                    </div>
                </div>
            </div>
        </section>
    </div>
</div>

@code {
    private string? _lastScrolledFragment;

    protected override void OnInitialized() =>
        Nav.LocationChanged += OnHelpLocationChanged;

    private void OnHelpLocationChanged(object? sender, LocationChangedEventArgs e) =>
        _lastScrolledFragment = null;

    protected override async Task OnAfterRenderAsync(bool firstRender) =>
        await ScrollToSectionIfNeededAsync();

    private async Task ScrollToSectionIfNeededAsync()
    {
        var uri = Nav.ToAbsoluteUri(Nav.Uri);
        if (!string.Equals(uri.AbsolutePath.TrimEnd('/'), "/help", StringComparison.OrdinalIgnoreCase))
            return;

        var fragment = uri.Fragment.TrimStart('#');
        if (string.IsNullOrEmpty(fragment) || fragment == _lastScrolledFragment)
            return;

        _lastScrolledFragment = fragment;

        try
        {
            await Js.InvokeVoidAsync("vscanmagic.scrollToHelpSection", fragment);
        }
        catch
        {
            // Non-critical if JS helper is unavailable.
        }
    }

    public void Dispose()
    {
        Nav.LocationChanged -= OnHelpLocationChanged;
    }
}
