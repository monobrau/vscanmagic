@page "/review/{SessionId}/deliverables"
@rendermode InteractiveServer
@using VScanMagic.Core.Models
@using VScanMagic.Core.Paths
@using VScanMagic.Core.Services
@using VScanMagic.Review
@using VScanMagic.Review.Models
@using VScanMagic.ConnectSecure
@using VScanMagic.ConnectWiseManage
@using VScanMagic.Reports
@inject IReviewSessionRepository SessionRepo
@inject TemplatesService TemplatesSvc
@inject RemediationRuleService RemediationRules
@inject SettingsService Settings
@inject ReportPathResolver PathResolver
@inject ReportFolderHistoryService FolderHistory
@inject ReviewUsernameRefreshService UsernameRefresh
@inject OutlookDeliverableDraftService OutlookDraft
@inject ConnectWiseManageTicketService ManageTickets

<PageTitle>Deliverables</PageTitle>

@if (_session is null)
{
    <p>Loading...</p>
}
else
{
    <div class="d-flex flex-wrap justify-content-between align-items-start gap-2 mb-3">
        <div>
            <h1>@_session.ClientName <HelpTip Text="Copy-paste content for Manage PSA and client email — paste OneDrive share links on the Email tab after export." AlignEnd="true" /></h1>
            <p class="text-muted mb-0">
                Scan: @_session.ScanDate | Presenter: @_session.Presenter | Export set: @ExportSetLabel()
                | Client type: @(_session.IsRmitPlus ? "RMIT+" : "RMIT/CMIT")
            </p>
        </div>
        <div class="d-flex flex-wrap gap-2">
            <a class="btn btn-outline-secondary" href="@($"/review/{SessionId}")">Back to review</a>
            <a class="btn btn-success" href="@($"/export/{SessionId}")">Export all</a>
        </div>
    </div>

    <div id="deliverable-copy-sources" hidden aria-hidden="true">
        <pre id="deliverable-time-estimate">@_timeEstimate</pre>
        <pre id="deliverable-ticket-notes">@_ticketNotes</pre>
        <pre id="deliverable-email-subject">@_emailSubject</pre>
        <pre id="deliverable-email-body">@_emailBodyForCopy</pre>
        @foreach (var section in _sections)
        {
            <pre id="deliverable-ticket-subject-@(section.SectionId)">@(section.Subject)</pre>
            <pre id="deliverable-ticket-body-@(section.SectionId)">@(section.BodyText)</pre>
        }
    </div>
    <div id="deliverable-email-body-html" hidden aria-hidden="true">@((MarkupString)_emailBodyHtml)</div>

    <ul class="nav nav-tabs mb-3">
        <li class="nav-item">
            <button type="button" class="nav-link @(_tab == "ticket" ? "active" : "")" @onclick='() => _tab = "ticket"'>
                Ticket instructions
            </button>
        </li>
        <li class="nav-item">
            <button type="button" class="nav-link @(_tab == "email" ? "active" : "")" @onclick='() => _tab = "email"'>
                Email template <HelpTip Text="Paste Top N and folder share links from Explorer after export. Outbound mail with the default subject is encrypted automatically; a copy goes to security-deliverables@river-run.com (not shown in Outlook compose)." />
            </button>
        </li>
        <li class="nav-item">
            <button type="button" class="nav-link @(_tab == "time" ? "active" : "")" @onclick='() => _tab = "time"'>
                Time estimate
            </button>
        </li>
        <li class="nav-item">
            <button type="button" class="nav-link @(_tab == "notes" ? "active" : "")" @onclick='() => _tab = "notes"'>
                Ticket notes (Manage PSA)
            </button>
        </li>
    </ul>

    @if (_tab == "ticket")
    {
        <div class="alert alert-info py-2">
            Use <strong>Copy subject</strong> / <strong>Copy section</strong> to paste into Manage PSA tickets, or create tickets via the Manage API when configured on Settings.
        </div>
        <div class="d-flex flex-wrap gap-2 mb-3">
            <button type="button" class="btn btn-success btn-sm" disabled="@_manageBusy" @onclick="CreateManageTicketsAsync">
                @(_manageBusy ? "Working..." : "Create Manage tickets")
            </button>
            <button type="button" class="btn btn-outline-success btn-sm" disabled="@_manageBusy" @onclick="RefreshManageTicketsAsync">
                Refresh ticket info
            </button>
        </div>
        @if (!string.IsNullOrEmpty(_manageStatus))
        {
            <div class="alert @(_manageError ? "alert-danger" : "alert-success") py-2">@_manageStatus</div>
        }

        @if (_sections.Count == 0)
        {
            <div class="alert alert-warning mb-0">No export findings in this session.</div>
        }
        else
        {
            @foreach (var section in _sections)
            {
                var sectionId = section.SectionId;
                var expanded = _expandedSections.Contains(sectionId);
                <div class="card mb-2">
                    <div class="card-header d-flex flex-wrap align-items-center gap-2">
                        <button type="button" class="btn btn-link text-start text-decoration-none flex-grow-1 p-0 deliverable-section-toggle"
                                @onclick="() => ToggleSection(sectionId)">
                            <span class="fw-semibold me-2">#@(section.Number)</span>
                            <span>@(section.Subject)</span>
                            <span class="text-muted ms-2">@(expanded ? "▾" : "▸")</span>
                        </button>
                        <div class="d-flex flex-wrap gap-2">
                            <button type="button" class="btn btn-primary btn-sm" data-vscan-copy-target="deliverable-ticket-subject-@sectionId">
                                Copy subject
                            </button>
                            <button type="button" class="btn btn-outline-primary btn-sm" data-vscan-copy-target="deliverable-ticket-body-@sectionId">
                                Copy section
                            </button>
                        </div>
                    </div>
                    @if (expanded)
                    {
                        <div class="card-body pt-0">
                            <pre class="deliverable-text mb-0">@(section.BodyText)</pre>
                        </div>
                    }
                </div>
            }
        }
    }
    else if (_tab == "email")
    {
        <div class="alert alert-info py-2 mb-3">
            <strong>Automatic encrypt and security copy</strong>
            <HelpTip Text="River Run Exchange mail flow rule: VScanMagic quarterly deliverable - encrypt and CC security. Requires external To address and default subject unchanged." />
            <ul class="mb-0 mt-2 small">
                <li>Enter the client’s <strong>external</strong> address in <strong>Client email (To)</strong>, then send from Outlook — do not change the subject line.</li>
                <li>Exchange applies <strong>Encrypt</strong> on send. You do <strong>not</strong> need to click Encrypt in Outlook.</li>
                <li>A copy is delivered to <strong>security-deliverables@river-run.com</strong> at send time. It will <strong>not</strong> appear in the Cc field while you compose, and you will not get that copy in your personal inbox.</li>
                <li>Open the shared <strong>Security Deliverables</strong> mailbox in Outlook to read encrypted copies. Do not Cc the Teams channel — it cannot receive encrypted mail.</li>
            </ul>
        </div>
        <div class="card mb-3">
            <div class="card-header">Email links for this deliverable</div>
            <div class="card-body">
                <p class="form-text">
                    After you export reports, use <strong>Copy link</strong> in Windows Explorer (or SharePoint) for the Top N doc and quarterly folder, then paste below.
                    The scheduling link defaults from <a href="/settings">Settings</a> unless you override it here.
                </p>
                <div class="mb-2">
                    <label class="form-label">Top N report link <HelpTip Text="Share link for this quarter's Top N Word/PDF — from Copy link in Explorer after you export and sync." /></label>
                    <input class="form-control form-control-sm" @bind="_session.TopNReportUrl" @bind:after="RefreshEmailPreview" placeholder="https://..." />
                </div>
                <div class="mb-2">
                    <label class="form-label">Quarterly reports folder link <HelpTip Text="Share link for the folder containing all quarterly reports for this client." /></label>
                    <input class="form-control form-control-sm" @bind="_session.ReportsFolderUrl" @bind:after="RefreshEmailPreview" placeholder="https://..." />
                </div>
                <div class="mb-3">
                    <label class="form-label">Scheduling link (TimeZest)</label>
                    <input class="form-control form-control-sm" @bind="_session.SchedulingLinkUrl" @bind:after="RefreshEmailPreview" placeholder="https://..." />
                </div>
                <div class="mb-3">
                    <label class="form-label">Client email (To) <HelpTip Text="External client address only. Internal-only sends do not match the Exchange rule. Saved on this session and used by Open client email in Outlook." /></label>
                    <input class="form-control form-control-sm" type="email" @bind="_session.ClientDeliverableEmail" @bind:after="OnClientEmailChanged" placeholder="client@their-domain.com" />
                </div>
                <button type="button" class="btn btn-outline-primary btn-sm" @onclick="SaveDeliverableLinksAsync">Save links on session</button>
                @if (!string.IsNullOrEmpty(_linksStatus))
                {
                    <span class="text-muted small ms-2">@_linksStatus</span>
                }
            </div>
        </div>
        <div class="card">
            <div class="card-body">
                <div class="d-flex flex-wrap gap-2 mb-3">
                    <button type="button" class="btn btn-primary btn-sm" data-vscan-copy-target="deliverable-email-subject">
                        Copy subject
                    </button>
                    <button type="button" class="btn btn-outline-primary btn-sm"
                            data-vscan-copy-target="deliverable-email-body"
                            data-vscan-copy-html-target="deliverable-email-body-html">
                        Copy body
                    </button>
                    @if (OutlookDraft.IsSupported)
                    {
                        <button type="button" class="btn btn-success btn-sm"
                                disabled="@_openingOutlookDraft"
                                @onclick="OpenClientEmailInOutlookAsync">
                            @(_openingOutlookDraft ? "Opening Outlook..." : "Open client email in Outlook")
                        </button>
                    }
                </div>
                @if (!string.IsNullOrEmpty(_outlookDraftStatus))
                {
                    <div class="alert @(_outlookDraftError ? "alert-danger" : "alert-success") py-2 mb-3">@_outlookDraftStatus</div>
                }
                else if (OutlookDraft.IsSupported)
                {
                    <p class="form-text mb-3">
                        <strong>Open client email in Outlook</strong> opens Classic Outlook with this subject, HTML body, and your default signature.
                        Review and click <strong>Send</strong> only — encrypt and the security-deliverables copy are added automatically by Exchange when the client address is external.
                    </p>
                }
                else
                {
                    <p class="form-text mb-3 text-muted">
                        Open in Outlook is available when VScanMagic Web runs on Windows with Classic Outlook installed.
                        Use copy subject/body otherwise.
                    </p>
                }
                <p class="form-text mb-2">Copy body places clickable links on the clipboard for New Outlook and ConnectWise Manage. The preview below matches what is copied.</p>
                <div id="deliverable-email-preview" class="deliverable-email-preview border rounded p-3 mb-3 bg-white">@((MarkupString)_emailBodyHtml)</div>
                <pre class="deliverable-text mb-0">@_emailBodyForCopy</pre>
            </div>
        </div>
    }
    else if (_tab == "time")
    {
        <div class="card">
            <div class="card-body">
                <button type="button" class="btn btn-primary btn-sm mb-3" data-vscan-copy-target="deliverable-time-estimate">
                    Copy time estimate
                </button>
                <pre class="deliverable-text mb-0">@_timeEstimate</pre>
            </div>
        </div>
    }
    else
    {
        <div class="card">
            <div class="card-body">
                <div class="d-flex flex-wrap gap-2 mb-3">
                    <button type="button" class="btn btn-primary btn-sm" data-vscan-copy-target="deliverable-ticket-notes">
                        Copy ticket notes
                    </button>
                    <button type="button" class="btn btn-outline-success btn-sm" disabled="@_manageBusy" @onclick="RefreshManageTicketsAsync">
                        Refresh ticket info
                    </button>
                </div>
                @if (!string.IsNullOrEmpty(_manageStatus) && _tab == "notes")
                {
                    <div class="alert @(_manageError ? "alert-danger" : "alert-success") py-2">@_manageStatus</div>
                }
                <pre class="deliverable-text mb-0">@_ticketNotes</pre>
            </div>
        </div>
    }
}

@code {
    [Parameter] public string SessionId { get; set; } = "";

    private ReviewSession? _session;
    private string _tab = "ticket";
    private IReadOnlyList<TicketInstructionSection> _sections = [];
    private string _emailContent = "";
    private string _emailSubject = "";
    private string _emailBodyForCopy = "";
    private string _emailBodyHtml = "";
    private string _ticketNotes = "";
    private string _timeEstimate = "";
    private string? _linksStatus;
    private string? _outlookDraftStatus;
    private bool _outlookDraftError;
    private bool _openingOutlookDraft;
    private bool _manageBusy;
    private string? _manageStatus;
    private bool _manageError;
    private UserSettings _userSettings = new();
    private readonly HashSet<string> _expandedSections = new(StringComparer.Ordinal);

    protected override async Task OnParametersSetAsync()
    {
        _session = await SessionRepo.GetAsync(SessionId);
        if (_session is null)
            return;

        _userSettings = Settings.LoadUserSettings();
        if (string.IsNullOrWhiteSpace(_session.TopNReportUrl) &&
            string.IsNullOrWhiteSpace(_session.ReportsFolderUrl) &&
            string.IsNullOrWhiteSpace(_session.SchedulingLinkUrl))
        {
            DeliverableLinksResolver.ApplyDefaultsToSession(_session, _userSettings);
            await SessionRepo.SaveAsync(_session);
        }

        await RefreshUsernamesForDeliverablesAsync();
        RefreshDeliverableContent();
    }

    private async Task RefreshUsernamesForDeliverablesAsync()
    {
        if (_session is null)
            return;

        var companyId = int.TryParse(_session.CompanyId, out var id) ? id : 0;
        var result = await UsernameRefresh.RefreshSessionAsync(_session, companyId, exportFindingsOnly: true);
        if (result.UsernamesFilled > 0)
            await SessionRepo.SaveAsync(_session);
    }

    private void RefreshDeliverableContent()
    {
        if (_session is null)
            return;

        var companyId = int.TryParse(_session.CompanyId, out var id) ? id : 0;
        var layout = SessionOutputLayoutResolver.ResolveForSession(
            PathResolver,
            _userSettings,
            _session.ClientName,
            _session.ScanDate,
            companyId,
            _session.OutputDirectory,
            _session.SourceFilePath,
            FolderHistory,
            _userSettings.LastOutputDirectory);

        var templates = TemplatesSvc.Load();
        var links = DeliverableLinksResolver.Resolve(_session, _userSettings);
        _sections = TicketInstructionBuilder.BuildSections(_session, RemediationRules, layout.ReportsPathPartial);
        _emailContent = EmailTemplateBuilder.Build(_session, templates, links);
        (_emailSubject, var emailBody) = EmailTemplateBuilder.SplitSubjectAndBody(_emailContent);
        var topNLabel = EmailTemplateBuilder.GetTopNLabel(_session);
        (_emailBodyForCopy, _emailBodyHtml) = EmailTemplateBuilder.PrepareDeliverableCopy(emailBody, links, topNLabel);
        _ticketNotes = TicketNotesBuilder.Build(_session, templates.TicketNotes, _session.IsRmitPlus);
        _timeEstimate = TimeEstimateBuilder.Build(_session, RemediationRules);
    }

    private void RefreshEmailPreview()
    {
        if (_session is null)
            return;

        var templates = TemplatesSvc.Load();
        var links = DeliverableLinksResolver.Resolve(_session, _userSettings);
        _emailContent = EmailTemplateBuilder.Build(_session, templates, links);
        (_emailSubject, var emailBody) = EmailTemplateBuilder.SplitSubjectAndBody(_emailContent);
        var topNLabel = EmailTemplateBuilder.GetTopNLabel(_session);
        (_emailBodyForCopy, _emailBodyHtml) = EmailTemplateBuilder.PrepareDeliverableCopy(emailBody, links, topNLabel);
        _linksStatus = null;
    }

    private async Task SaveDeliverableLinksAsync()
    {
        if (_session is null)
            return;

        _session.TopNReportUrl = _session.TopNReportUrl.Trim();
        _session.ReportsFolderUrl = _session.ReportsFolderUrl.Trim();
        _session.SchedulingLinkUrl = _session.SchedulingLinkUrl.Trim();
        _session.ClientDeliverableEmail = _session.ClientDeliverableEmail.Trim();
        await SessionRepo.SaveAsync(_session);
        RefreshEmailPreview();
        _linksStatus = "Saved.";
    }

    private void OnClientEmailChanged()
    {
        _outlookDraftStatus = null;
        _outlookDraftError = false;
        _linksStatus = null;
    }

    private async Task CreateManageTicketsAsync()
    {
        if (_session is null)
            return;

        _manageStatus = null;
        _manageError = false;
        _manageBusy = true;
        try
        {
            var result = await ManageTickets.CreateTicketsForSessionAsync(_session);
            await SessionRepo.SaveAsync(_session);
            RefreshDeliverableContent();
            _manageStatus = $"Created {result.Created}, skipped {result.Skipped}, failed {result.Failed}.";
            _manageError = result.Failed > 0 && result.Created == 0;
        }
        catch (Exception ex)
        {
            _manageStatus = ex.Message;
            _manageError = true;
        }
        finally
        {
            _manageBusy = false;
        }
    }

    private async Task RefreshManageTicketsAsync()
    {
        if (_session is null)
            return;

        _manageStatus = null;
        _manageError = false;
        _manageBusy = true;
        try
        {
            var count = await ManageTickets.RefreshTicketsForSessionAsync(_session);
            await SessionRepo.SaveAsync(_session);
            RefreshDeliverableContent();
            _manageStatus = count > 0
                ? $"Refreshed {count} ticket(s). Ticket notes updated below."
                : "No Manage tickets to refresh on this session.";
        }
        catch (Exception ex)
        {
            _manageStatus = ex.Message;
            _manageError = true;
        }
        finally
        {
            _manageBusy = false;
        }
    }

    private async Task OpenClientEmailInOutlookAsync()
    {
        if (_session is null)
            return;

        _outlookDraftStatus = null;
        _outlookDraftError = false;

        if (!OutlookDeliverableDraftService.TryValidateClientEmail(
                _session.ClientDeliverableEmail,
                out var toAddress,
                out var validationError))
        {
            _outlookDraftStatus = validationError;
            _outlookDraftError = true;
            return;
        }

        _session.ClientDeliverableEmail = toAddress;
        await SessionRepo.SaveAsync(_session);

        _openingOutlookDraft = true;
        try
        {
            var result = await OutlookDraft.OpenClientEmailDraftAsync(
                toAddress,
                _emailSubject,
                _emailBodyHtml);

            _outlookDraftStatus = result.Message;
            _outlookDraftError = !result.Success;
        }
        catch (Exception ex)
        {
            _outlookDraftStatus = ex.Message;
            _outlookDraftError = true;
        }
        finally
        {
            _openingOutlookDraft = false;
        }
    }

    private string ExportSetLabel()
    {
        if (_session is null)
            return "";

        var exportCount = ReviewSessionRanker.GetExportFindings(_session).Count;
        var manual = _session.Findings.Count(f => f.IncludeInExport && f.ManuallyPromoted);
        if (_session.ExportTopN <= 0)
            return $"All ({exportCount})";

        return manual > 0
            ? $"{exportCount} in export (Top {_session.ExportTopN} suggested + {manual} added)"
            : $"{exportCount} in export (Top {_session.ExportTopN})";
    }

    private void ToggleSection(string sectionId)
    {
        if (!_expandedSections.Add(sectionId))
            _expandedSections.Remove(sectionId);
    }
}
