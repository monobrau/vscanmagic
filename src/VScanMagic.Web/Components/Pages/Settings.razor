@page "/settings"
@rendermode InteractiveServer
@using VScanMagic.ConnectSecure
@using VScanMagic.ConnectWiseManage
@inject SettingsService SettingsSvc
@inject ConnectSecureClient ConnectSecure
@inject ConnectWiseManageClient ManageClient
@inject ConnectWiseManageSettingsStore ManageSettingsStore
@inject IJSRuntime Js

<PageTitle>Settings</PageTitle>

<h1>Settings <HelpTip Text="Global defaults used across all clients. See Help for first-time setup order." /></h1>

<div class="card mb-3">
    <div class="card-header">Report Output Paths</div>
    <div class="card-body">
        <div class="mb-2">
            <label class="form-label">Reports Base Path <HelpTip Text="Local synced root containing client folders (OneDrive/SharePoint). Exports go under [client]\Network Documentation\Vulnerability Scans\[year-quarter]\. This is not a share URL." AlignEnd="true" /></label>
            <input class="form-control" @bind="_user.ReportsBasePath" placeholder="/path/to/client documentation root" />
            <div class="form-text">
                Parent folder that contains each client (e.g. folders named after clients, not this app&apos;s download folder).
                Exports go under <code>[client]\Network Documentation\Vulnerability Scans\[year-quarter]\</code>.
                Ticket/email copy-paste content is in the app under <strong>Deliverables</strong> during review.
            </div>
        </div>
        <div class="mb-2">
            <label class="form-label">Last Output Directory</label>
            <input class="form-control" @bind="_user.LastOutputDirectory" placeholder="Fallback when base path is unset or client folder cannot be matched" />
        </div>
    </div>
</div>

<div class="card mb-3">
    <div class="card-header">Deliverable email links</div>
    <div class="card-body">
        <p class="form-text">
            Default TimeZest scheduling link for deliverable emails. OneDrive/SharePoint links for the Top N report and quarterly folder are pasted on the
            review <strong>Deliverables</strong> page after you export and copy share links from Windows Explorer.
        </p>
        <div class="mb-0">
            <label class="form-label">Scheduling link (TimeZest) <HelpTip Text="Default {SchedulingLink} in client emails. OneDrive links are pasted per quarter on Deliverables after Copy link in Explorer." AlignEnd="true" /></label>
            <input class="form-control" @bind="_user.SchedulingLinkUrl" placeholder="https://..." />
            <div class="form-text mb-0">Inserted as <code>{SchedulingLink}</code> in the email template.</div>
        </div>
    </div>
</div>

<div class="card mb-3">
    <div class="card-header">Report Identity</div>
    <div class="card-body">
        <div class="mb-2"><label class="form-label">Prepared By <HelpTip Text="Default presenter name for new review sessions and email signatures." /></label><input class="form-control" @bind="_user.PreparedBy" /></div>
        <div class="mb-2"><label class="form-label">Company Name</label><input class="form-control" @bind="_user.CompanyName" /></div>
        <div class="mb-2"><label class="form-label">Email</label><input class="form-control" @bind="_user.Email" /></div>
    </div>
</div>

<div class="card mb-3">
    <div class="card-header">Report Filters</div>
    <div class="card-body">
        <div class="mb-2"><label class="form-label">Min EPSS</label><input class="form-control" type="number" step="0.01" @bind="_user.FilterMinEpss" /></div>
        <div class="mb-2">
            <label class="form-label">Top N vulnerabilities <HelpTip Text="How many findings are in the initial export set when a review session starts. You can promote more from Add to export during review." /></label>
            <select class="form-select" @bind="_topNPreset" @bind:after="SyncTopNFromPreset">
                <option value="10">Top 10</option>
                <option value="20">Top 20</option>
                <option value="50">Top 50</option>
                <option value="100">Top 100</option>
                <option value="All">All (no limit)</option>
                <option value="Custom">Custom…</option>
            </select>
        </div>
        @if (_topNPreset == "Custom")
        {
            <div class="mb-2">
                <label class="form-label">Custom count</label>
                <input class="form-control" type="number" min="1" max="500" @bind="_customTopN" @bind:after="ApplyCustomTopN" />
            </div>
        }
        <div class="form-text mb-2">Controls how many vulnerabilities are in the export set. Additional reserves are loaded for promotion when you exclude an item during review.</div>
        <div class="form-check"><input type="checkbox" class="form-check-input" checked="@_user.FilterIncludeCritical" @onclick="e => OnSeverityCheckboxClick(0, e)" @onclick:preventDefault id="c" /><label for="c">Critical</label></div>
        <div class="form-check"><input type="checkbox" class="form-check-input" checked="@_user.FilterIncludeHigh" @onclick="e => OnSeverityCheckboxClick(1, e)" @onclick:preventDefault id="h" /><label for="h">High</label></div>
        <div class="form-check"><input type="checkbox" class="form-check-input" checked="@_user.FilterIncludeMedium" @onclick="e => OnSeverityCheckboxClick(2, e)" @onclick:preventDefault id="m" /><label for="m">Medium</label></div>
        <div class="form-check"><input type="checkbox" class="form-check-input" checked="@_user.FilterIncludeLow" @onclick="e => OnSeverityCheckboxClick(3, e)" @onclick:preventDefault id="l" /><label for="l">Low</label></div>
        <p class="form-text mb-0">Shift-click to toggle a range of severity levels.</p>
    </div>
</div>

<div class="card mb-3">
    <div class="card-header">CVE enrichment (NVD)</div>
    <div class="card-body">
        <p class="form-text">
            Fetches descriptions and vendor advisory links from the
            <a href="https://nvd.nist.gov/developers/vulnerabilities" target="_blank" rel="noopener">NVD API</a>
            for findings with CVE IDs and no ConnectSecure fix text. Results are cached under your config folder.
        </p>
        <div class="form-check mb-3">
            <input class="form-check-input" type="checkbox" @bind="_user.NvdEnrichOnIngest" id="nvdEnrichOnIngest" />
            <label class="form-check-label" for="nvdEnrichOnIngest">Auto-fetch NVD details for the export Top N when a review session opens</label>
            <div class="form-text">Network, registry, and other candidates are enriched when you add them to export or use Fetch NVD details. Requires outbound HTTPS to NVD.</div>
        </div>
        <div class="mb-0">
            <label class="form-label">NVD API key (optional)</label>
            <input class="form-control" type="password" @bind="_user.NvdApiKey" autocomplete="off" placeholder="Higher rate limits — request at nvd.nist.gov/developers" />
            <div class="form-text mb-0">Without a key, lookups are limited to about 5 requests per 30 seconds.</div>
        </div>
    </div>
</div>

<div class="card mb-3">
    <div class="card-header">OS host selection</div>
    <div class="card-body">
        <p class="form-text mb-3">
            For <strong>operating-system</strong> findings from the Application scan only, hosts with fewer vulnerabilities than the threshold start unchecked.
            Registry findings, network findings, and third-party applications are never auto-filtered.
            Set to <strong>0</strong> to include all hosts for that OS category.
        </p>
        <div class="mb-2">
            <label class="form-label">Windows 11 — minimum host vuln count</label>
            <input class="form-control" type="number" min="0" max="9999" @bind="_user.HostVulnThresholdWindows11" />
            <div class="form-text">Default 350 (matches legacy VScanMagic). Hosts below this are unselected for Windows 11 tabs.</div>
        </div>
        <div class="mb-2">
            <label class="form-label">Other Windows — minimum host vuln count</label>
            <input class="form-control" type="number" min="0" max="9999" @bind="_user.HostVulnThresholdWindowsOther" />
            <div class="form-text">Windows 10, Windows Server, etc. 0 = include all hosts.</div>
        </div>
        <div class="mb-2">
            <label class="form-label">Other operating systems — minimum host vuln count</label>
            <input class="form-control" type="number" min="0" max="9999" @bind="_user.HostVulnThresholdOtherOs" />
            <div class="form-text">Linux, macOS, ESXi, etc. 0 = include all hosts.</div>
        </div>
    </div>
</div>

<div class="card mb-3">
    <div class="card-header">ConnectSecure API</div>
    <div class="card-body">
        <p class="text-muted small mb-2">
            Copy all four values from the same screen: <strong>Global → Settings → Users → API Key</strong>.
            The Client Secret is usually a long base64 string (<code>Z0FB…</code>) — paste it exactly as shown.
        </p>
        <div class="mb-2">
            <label class="form-label">Base URL</label>
            <input class="form-control" @bind="_creds.BaseUrl" placeholder="https://pod0.myconnectsecure.com" />
        </div>
        <div class="mb-2">
            <label class="form-label">Tenant</label>
            <input class="form-control" @bind="_creds.TenantName" placeholder="example-tenant" />
            <div class="form-text">Must match the tenant name you use to log in (case-sensitive).</div>
        </div>
        <div class="mb-2">
            <label class="form-label">Client ID</label>
            <input class="form-control" @bind="_creds.ClientId" />
        </div>
        <div class="mb-2">
            <label class="form-label">Client Secret</label>
            <input class="form-control" type="password" @bind="_creds.ClientSecret" autocomplete="off" />
        </div>
        @if (_secretLooksEncoded)
        {
            <div class="alert alert-info py-2">
                Client Secret format looks normal for ConnectSecure. It is sent as-is to <code>/w/authorize</code>.
            </div>
        }
        @if (!string.IsNullOrWhiteSpace(_creds.BaseUrl))
        {
            <p class="small mb-2">
                Swagger: <a href="@ConnectSecureCredentialsHelper.GetSwaggerUrl(_creds)" target="_blank" rel="noopener">@ConnectSecureCredentialsHelper.GetSwaggerUrl(_creds)</a>
            </p>
        }
        @if (_showSwaggerToken)
        {
            <div class="mb-2">
                <label class="form-label">Client-Auth-Token (for Swagger POST /w/authorize)</label>
                <textarea class="form-control font-monospace small" rows="3" readonly>@_swaggerToken</textarea>
                <button type="button" class="btn btn-sm btn-outline-secondary mt-1" @onclick="CopySwaggerToken">Copy token</button>
            </div>
        }
    </div>
</div>

<div class="card mb-3">
    <div class="card-header">ConnectWise Manage (PSA)</div>
    <div class="card-body">
        <p class="text-muted small mb-2">
            API credentials from Manage: <strong>System → Members → API Members → API Keys</strong>.
            API URL is typically <code>https://na.myconnectwise.net/v4_6_release/apis/3.0</code> (use your site base before <code>/apis/3.0</code>).
        </p>
        <div class="mb-2">
            <label class="form-label">API URL</label>
            <input class="form-control" @bind="_manageCreds.ApiUrl" placeholder="https://na.myconnectwise.net/v4_6_release" />
        </div>
        <div class="mb-2">
            <label class="form-label">Company ID (auth)</label>
            <input class="form-control" @bind="_manageCreds.CompanyId" placeholder="riverrun" />
        </div>
        <div class="mb-2">
            <label class="form-label">Public key</label>
            <input class="form-control" @bind="_manageCreds.PublicKey" />
        </div>
        <div class="mb-2">
            <label class="form-label">Private key</label>
            <input class="form-control" type="password" @bind="_manageCreds.PrivateKey" autocomplete="off" />
        </div>
        <div class="mb-2">
            <label class="form-label">Client ID header</label>
            <input class="form-control" @bind="_manageCreds.ClientId" placeholder="VScanMagic" />
        </div>
        <div class="row mb-2">
            <div class="col-md-6">
                <label class="form-label">Default service board</label>
                <select class="form-select" @bind="_manageOptions.DefaultBoardId" @bind:after="OnManageBoardChanged">
                    <option value="0">-- Select board --</option>
                    @foreach (var board in _manageBoards)
                    {
                        <option value="@board.Id">@board.Name</option>
                    }
                </select>
            </div>
            <div class="col-md-6">
                <label class="form-label">Default new-ticket status</label>
                <select class="form-select" @bind="_manageOptions.DefaultStatusId">
                    <option value="0">-- Select status --</option>
                    @foreach (var status in _manageStatuses)
                    {
                        <option value="@status.Id">@status.Name</option>
                    }
                </select>
            </div>
        </div>
        <button type="button" class="btn btn-outline-secondary btn-sm me-2" disabled="@_busy" @onclick="LoadManageBoardsAsync">Load boards</button>
        <button type="button" class="btn btn-outline-primary btn-sm" disabled="@_busy" @onclick="TestManageConnectionAsync">Test Manage connection</button>
        @if (!string.IsNullOrEmpty(_manageStatus))
        {
            <div class="form-text mt-2 mb-0">@_manageStatus</div>
        }
    </div>
</div>

@if (!string.IsNullOrEmpty(_message))
{
    <div class="alert alert-success">@_message</div>
}
@if (!string.IsNullOrEmpty(_error))
{
    <div class="alert alert-danger">@_error</div>
}

<button class="btn btn-primary me-2" disabled="@_busy" @onclick="Save">Save Settings</button>
<button class="btn btn-outline-primary me-2" disabled="@_busy" @onclick="TestCredentials">Test Credentials</button>
<button class="btn btn-outline-secondary" disabled="@_busy" @onclick="ShowSwaggerToken">Show Swagger token</button>

@code {
    private UserSettings _user = new();
    private ConnectSecureCredentials _creds = new();
    private ConnectWiseManageCredentials _manageCreds = new();
    private ConnectWiseManageOptions _manageOptions = new();
    private List<ManageBoard> _manageBoards = [];
    private List<ManageStatus> _manageStatuses = [];
    private string? _manageStatus;
    private string? _message;
    private string? _error;
    private bool _busy;
    private bool _secretLooksEncoded;
    private bool _showSwaggerToken;
    private string _swaggerToken = "";
    private string _topNPreset = "10";
    private string _customTopN = "10";
    private readonly CheckboxRangeColumn _severityRange = new();

    protected override void OnInitialized()
    {
        _user = SettingsSvc.LoadUserSettings();
        _creds = SettingsSvc.LoadConnectSecureCredentials();
        _manageCreds = ManageSettingsStore.LoadCredentials();
        _manageOptions = ManageSettingsStore.LoadOptions();
        if (ManageClient.IsConfigured || HasManageCredentialFields())
            ConfigureManageClient();
        LoadTopNPreset();
        UpdateSecretHint();
    }

    private void LoadTopNPreset()
    {
        var value = _user.FilterTopN?.Trim() ?? "10";
        if (value is "10" or "20" or "50" or "100" or "All")
        {
            _topNPreset = value;
            _customTopN = "10";
        }
        else
        {
            _topNPreset = "Custom";
            _customTopN = value;
        }
    }

    private void SyncTopNFromPreset()
    {
        if (_topNPreset == "Custom")
            _user.FilterTopN = _customTopN;
        else
            _user.FilterTopN = _topNPreset;
    }

    private void ApplyCustomTopN()
    {
        if (_topNPreset == "Custom")
            _user.FilterTopN = _customTopN;
    }

    private bool GetSeverityFilter(int index) => index switch
    {
        0 => _user.FilterIncludeCritical,
        1 => _user.FilterIncludeHigh,
        2 => _user.FilterIncludeMedium,
        3 => _user.FilterIncludeLow,
        _ => false
    };

    private void SetSeverityFilter(int index, bool value)
    {
        switch (index)
        {
            case 0: _user.FilterIncludeCritical = value; break;
            case 1: _user.FilterIncludeHigh = value; break;
            case 2: _user.FilterIncludeMedium = value; break;
            case 3: _user.FilterIncludeLow = value; break;
        }
    }

    private void OnSeverityCheckboxClick(int index, MouseEventArgs e)
    {
        var newValue = !GetSeverityFilter(index);
        _severityRange.Click(index, newValue, e, SetSeverityFilter);
    }

    private void UpdateSecretHint()
    {
        _secretLooksEncoded = ConnectSecureCredentialsHelper.IsConnectSecureEncodedSecret(_creds.ClientSecret);
    }

    private void Save()
    {
        _error = null;
        _message = null;
        UpdateSecretHint();

        var issues = ConnectSecureCredentialsHelper.Validate(_creds);
        if (issues.Count > 0)
        {
            _error = string.Join(" ", issues);
            return;
        }

        SettingsSvc.SaveUserSettings(_user);
        SettingsSvc.SaveConnectSecureCredentials(_creds);
        ConnectSecure.Configure(_creds);
        ManageSettingsStore.SaveCredentials(_manageCreds);
        ManageSettingsStore.SaveOptions(_manageOptions);
        ConfigureManageClient();
        _message = "Settings saved.";
    }

    private bool HasManageCredentialFields() =>
        !string.IsNullOrWhiteSpace(_manageCreds.ApiUrl) &&
        !string.IsNullOrWhiteSpace(_manageCreds.CompanyId) &&
        !string.IsNullOrWhiteSpace(_manageCreds.PublicKey) &&
        !string.IsNullOrWhiteSpace(_manageCreds.PrivateKey) &&
        !string.IsNullOrWhiteSpace(_manageCreds.ClientId);

    private void ConfigureManageClient()
    {
        if (!HasManageCredentialFields())
            return;
        ManageClient.Configure(_manageCreds);
    }

    private async Task LoadManageBoardsAsync()
    {
        _error = null;
        _manageStatus = null;
        if (!HasManageCredentialFields())
        {
            _error = "Enter ConnectWise Manage credentials first.";
            return;
        }

        _busy = true;
        try
        {
            ConfigureManageClient();
            _manageBoards = (await ManageClient.GetBoardsAsync()).OrderBy(b => b.Name).ToList();
            _manageStatus = $"Loaded {_manageBoards.Count} board(s).";
            if (_manageOptions.DefaultBoardId > 0)
                await LoadManageStatusesAsync(_manageOptions.DefaultBoardId);
        }
        catch (Exception ex)
        {
            _error = ex.Message;
        }
        finally
        {
            _busy = false;
        }
    }

    private async Task OnManageBoardChanged()
    {
        _manageStatuses = [];
        if (_manageOptions.DefaultBoardId > 0)
            await LoadManageStatusesAsync(_manageOptions.DefaultBoardId);
    }

    private async Task LoadManageStatusesAsync(int boardId)
    {
        if (!ManageClient.IsConfigured)
            return;

        _manageStatuses = (await ManageClient.GetBoardStatusesAsync(boardId)).OrderBy(s => s.Name).ToList();
    }

    private async Task TestManageConnectionAsync()
    {
        _error = null;
        _manageStatus = null;
        if (!HasManageCredentialFields())
        {
            _error = "Enter ConnectWise Manage credentials first.";
            return;
        }

        _busy = true;
        try
        {
            ConfigureManageClient();
            _manageStatus = await ManageClient.TestConnectionAsync();
            _manageBoards = (await ManageClient.GetBoardsAsync()).OrderBy(b => b.Name).ToList();
            if (_manageOptions.DefaultBoardId > 0)
                await LoadManageStatusesAsync(_manageOptions.DefaultBoardId);
        }
        catch (Exception ex)
        {
            _error = ex.Message;
        }
        finally
        {
            _busy = false;
        }
    }

    private async Task TestCredentials()
    {
        _error = null;
        _message = null;
        UpdateSecretHint();

        var issues = ConnectSecureCredentialsHelper.Validate(_creds);
        if (issues.Count > 0)
        {
            _error = string.Join(" ", issues);
            return;
        }

        _busy = true;
        try
        {
            ConnectSecure.Configure(_creds);
            await ConnectSecure.TestAuthenticationAsync();
            var companies = await ConnectSecure.GetCompaniesAsync();
            _message = $"Credentials are valid. Loaded {companies.Count} company/companies.";
        }
        catch (Exception ex)
        {
            _error = ex.Message;
        }
        finally
        {
            _busy = false;
        }
    }

    private void ShowSwaggerToken()
    {
        _error = null;
        var issues = ConnectSecureCredentialsHelper.Validate(_creds);
        if (issues.Count > 0)
        {
            _error = string.Join(" ", issues);
            return;
        }

        _swaggerToken = ConnectSecureCredentialsHelper.BuildClientAuthToken(_creds);
        _showSwaggerToken = true;
    }

    private async Task CopySwaggerToken()
    {
        if (string.IsNullOrWhiteSpace(_swaggerToken))
            ShowSwaggerToken();
        await Js.InvokeAsync<bool>("vscanmagic.copyText", _swaggerToken);
        _message = "Client-Auth-Token copied. Paste it into Swagger POST /w/authorize.";
    }
}
